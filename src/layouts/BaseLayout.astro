---
import { ClientRouter } from "astro:transitions"
import "../styles/global.css"
import { Navbar } from "@/components/Navbar"
import Footer from "@/components/Footer.astro"
import ThemeProvider from "@/components/ThemeProvider.astro"
import { siteConfig, getLocationText } from "@/config/site"
import PopupModal from "@/components/ui/PopupModal.astro"
import FreeScanButton from "@/components/ui/FreeScanButton.astro"
import FAQSection from "@/components/sections/FAQSection.astro"
import ServiceAreaSection from "@/components/sections/ServiceAreaSection.astro"
import CTABannerSection from "@/components/sections/CTABannerSection.astro"

interface Props {
  title: string
  description?: string
  keywords?: string
  ogImage?: string
  noindex?: boolean
}

const { 
  title: rawTitle, 
  description: rawDescription = siteConfig.seo.defaultDescription,
  keywords = siteConfig.seo.keywords,
  ogImage = siteConfig.seo.ogImage,
  noindex = false,
} = Astro.props

const description = getLocationText(rawDescription)
const fullTitle = rawTitle.includes(siteConfig.seo.siteName) ? rawTitle : `${rawTitle} | ${siteConfig.seo.siteName}`
const canonical = new URL(Astro.url.pathname, siteConfig.seo.siteUrl).href
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    
    <title>{fullTitle}</title>
    <meta name="description" content={description} />
    <meta name="keywords" content={keywords} />
    
    {noindex ? (
      <meta name="robots" content="noindex, nofollow" />
    ) : (
      <meta name="robots" content="index, follow" />
    )}
    
    <link rel="canonical" href={canonical} />
    
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonical} />
    <meta property="og:title" content={fullTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImage} />
    
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="theme-color" content={siteConfig.colors.primary} />
    
    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:site" content={siteConfig.seo.twitterHandle} />
    <meta name="twitter:title" content={fullTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />
    
    <!-- Structured Data -->
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "LocalBusiness",
      "name": siteConfig.business.name,
      "description": description,
      "url": siteConfig.seo.siteUrl,
      "telephone": siteConfig.contact.phoneFormatted,
      "email": siteConfig.contact.email,
      "address": {
        "@type": "PostalAddress",
        "streetAddress": siteConfig.location.address,
        "addressLocality": siteConfig.location.city,
        "addressRegion": siteConfig.location.state
      }
    })} />
    
    <!-- Preconnect to critical origins -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    
    <!-- Archivo font from Google Fonts -->
    <link href="https://fonts.googleapis.com/css2?family=Archivo:wght@300;400;500;600;700;800;900&display=swap" rel="stylesheet" media="print" onload="this.media='all'" />
    <noscript>
      <link href="https://fonts.googleapis.com/css2?family=Archivo:wght@300;400;500;600;700;800;900&display=swap" rel="stylesheet" />
    </noscript>
    
    <ClientRouter />
    <ThemeProvider />
  </head>
  <body class="min-h-screen flex flex-col">
    <Navbar client:idle />
    <main class="flex-1">
      <slot />
    </main>
    
    <!-- Global sections that appear on all pages -->
    <FAQSection
      badge="FAQ"
      title="Frequently Asked Questions"
      description="Find answers to common questions about our HVAC services, pricing, and maintenance plans."
      faqs={[
        {
          question: "How often should I service my HVAC system?",
          answer: "We recommend servicing your HVAC system at least twice a year - once before the cooling season and once before the heating season. Regular maintenance helps prevent breakdowns, improves efficiency, and extends the life of your system."
        },
        {
          question: "What are signs that my AC needs repair?",
          answer: "Common signs include weak airflow, warm air blowing from vents, unusual noises, strange odors, frequent cycling, high energy bills, and moisture or leaks around the unit. If you notice any of these issues, contact us for a professional inspection."
        },
        {
          question: "Do you offer emergency HVAC services?",
          answer: "Yes! We provide 24/7 emergency HVAC services for urgent heating and cooling issues. Whether it's a broken AC in summer or a failed heater in winter, our technicians are ready to help restore your comfort quickly."
        },
        {
          question: "Do you offer financing options?",
          answer: "Yes, we offer flexible financing options to make HVAC repairs, replacements, and installations more affordable. Contact us to learn about our current financing plans and find one that fits your budget."
        }
      ]}
    />

    <!-- ServiceAreaSection appears after FAQ on non-location pages -->
    {!(Astro.url.pathname === '/santa-monica' || 
        Astro.url.pathname === '/pasadena' || 
        Astro.url.pathname === '/glendale' ||
        Astro.url.pathname === '/santa-monica/' || 
        Astro.url.pathname === '/pasadena/' || 
        Astro.url.pathname === '/glendale/') && (
      <ServiceAreaSection
        title="Heating & Cooling Solutions in Your Area"
        description=""
        areas={[
          "Santa Monica", "Pasadena", "Glendale"
        ]}
      />
    )}

    <CTABannerSection
      badge="READY FOR COMFORT?"
      title="Ready to Experience Superior HVAC Service?"
      description="Partner with us to transform your home comfort and achieve reliable heating and cooling. Let's create something amazing together."
      buttonText="Get Started Today"
      buttonHref="/contact"
      backgroundImage="/images/compagnons-yZmHFF-g-W0-unsplash.jpg"
    />
    
    <Footer />
    <FreeScanButton />
    <PopupModal />

    <script>
      // Optimize scroll animations for mobile
      function initScrollAnimations() {
        // Skip animations on mobile for better performance
        if (window.innerWidth < 768) {
          document.querySelectorAll('[data-animate], [data-animate-stagger]').forEach((el) => {
            el.classList.add('is-visible');
          });
          return;
        }

        const observer = new IntersectionObserver(
          (entries) => {
            entries.forEach((entry) => {
              if (entry.isIntersecting) {
                entry.target.classList.add('is-visible');
                observer.unobserve(entry.target);
              }
            });
          },
          { threshold: 0.1, rootMargin: '0px 0px -40px 0px' }
        );

        document.querySelectorAll('[data-animate], [data-animate-stagger]').forEach((el) => {
          observer.observe(el);
        });
      }

      // Run on initial load
      initScrollAnimations();

      // Re-run after Astro page transitions
      document.addEventListener('astro:page-load', initScrollAnimations);
    </script>
  </body>
</html>
