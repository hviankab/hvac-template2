---
interface Step {
  title: string;
  description: string;
}

interface Props {
  badge?: string;
  title: string;
  description: string;
  paymentPlans: string[];
  financingOptions: string[];
  steps: Step[];
  buttonText?: string;
  buttonHref?: string;
}

const {
  badge,
  title,
  description,
  paymentPlans,
  financingOptions,
  steps,
  buttonText = "Apply Now",
  buttonHref = "/financing",
} = Astro.props;
---

<section class="fin-section py-20 md:py-28">
  <div class="container mx-auto px-4">

    <!-- Header -->
    <div class="fin-header" data-animate="fade-scale">
      <div class="fin-badge-row">
        <span class="fin-accent-line"></span>
        <span class="fin-badge">Financing</span>
        <span class="fin-accent-line"></span>
      </div>
      <h2 class="fin-title">{title}</h2>
      <p class="fin-desc" set:html={description} />
    </div>

    <!-- Two-column lists -->
    <div class="fin-lists">
      <div class="fin-list-card" data-animate="fade-right">
        <h3 class="fin-list-heading">Why Choose Our Financing?</h3>
        <ul class="fin-list">
          {paymentPlans.map((plan) => (
            <li class="fin-list-item">
              <span class="fin-check">
                <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
              </span>
              <span>{plan}</span>
            </li>
          ))}
        </ul>
      </div>

      <div class="fin-list-card" data-animate="fade-left" data-animate-delay="200">
        <h3 class="fin-list-heading">What Can You Finance?</h3>
        <ul class="fin-list">
          {financingOptions.map((option) => (
            <li class="fin-list-item">
              <span class="fin-check">
                <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
              </span>
              <span>{option}</span>
            </li>
          ))}
        </ul>
      </div>
    </div>

    <!-- Steps -->
    <div class="fin-steps" data-animate-stagger>
      {steps.map((step, i) => (
        <div class="fin-step">
          <div class="fin-step-top">
            <div class="fin-step-num">{i + 1}</div>
            {i < steps.length - 1 && <div class="fin-step-line" aria-hidden="true"></div>}
          </div>
          <h4 class="fin-step-title">{step.title}</h4>
          <p class="fin-step-text" set:html={step.description} />
        </div>
      ))}
    </div>

    <!-- CTA -->
    <div class="fin-cta" data-animate="fade-up">
      <a href={buttonHref} class="fin-btn">
        {buttonText}
        <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
      </a>
    </div>
  </div>
</section>

<style>
  .fin-section {
    background: var(--brand-tertiary);
  }

  .fin-header {
    text-align: center;
    margin-bottom: 3rem;
    max-width: 48rem;
    margin-left: auto;
    margin-right: auto;
  }

  .fin-badge-row {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.75rem;
    margin-bottom: 1rem;
  }
  .fin-accent-line {
    width: 2.5rem;
    height: 3px;
    border-radius: 2px;
    background: var(--brand-highlight);
  }
  .fin-badge {
    font-size: 0.8rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--brand-secondary);
  }

  .fin-title {
    color: var(--foreground);
    line-height: 1.15;
    margin-bottom: 1rem;
  }

  .fin-desc {
    font-size: 1.125rem;
    line-height: 1.7;
    color: var(--muted-foreground);
  }

  /* Two-column list cards */
  .fin-lists {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1.5rem;
    max-width: 64rem;
    margin: 0 auto 3.5rem;
  }

  .fin-list-card {
    background: var(--card);
    border: 1.5px solid var(--border);
    border-radius: 1rem;
    padding: 2rem;
    transition: box-shadow 0.3s ease;
  }
  .fin-list-card:hover {
    box-shadow: 0 12px 32px color-mix(in srgb, var(--brand-secondary) 8%, transparent);
  }

  .fin-list-heading {
    font-size: 1.25rem;
    font-weight: 700;
    color: var(--foreground);
    margin-bottom: 1.25rem;
    padding-bottom: 0.75rem;
    border-bottom: 2px solid var(--brand-highlight);
  }

  .fin-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 0.875rem;
  }

  .fin-list-item {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    font-size: 1.05rem;
    color: var(--foreground);
  }

  .fin-check {
    width: 1.75rem;
    height: 1.75rem;
    border-radius: 50%;
    background: var(--brand-secondary);
    color: #fff;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
    border: 2px solid var(--brand-highlight);
  }

  /* Steps row */
  .fin-steps {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.5rem;
    max-width: 56rem;
    margin: 0 auto 3rem;
  }

  .fin-step {
    text-align: center;
    position: relative;
  }

  .fin-step-top {
    display: flex;
    align-items: center;
    justify-content: center;
    margin-bottom: 1.25rem;
    position: relative;
  }

  .fin-step-num {
    width: 3.25rem;
    height: 3.25rem;
    border-radius: 50%;
    background: var(--brand-secondary);
    color: #fff;
    font-family: 'Poppins', system-ui, sans-serif;
    font-weight: 700;
    font-size: 1.25rem;
    display: flex;
    align-items: center;
    justify-content: center;
    position: relative;
    z-index: 2;
    box-shadow: 0 4px 16px color-mix(in srgb, var(--brand-secondary) 25%, transparent);
    border: 2px solid var(--brand-highlight);
  }

  .fin-step-line {
    position: absolute;
    top: 50%;
    left: calc(50% + 2rem);
    width: calc(100% - 2rem);
    height: 2px;
    background: var(--brand-secondary);
    opacity: 0.2;
    z-index: 1;
  }

  .fin-step-title {
    font-size: 1.15rem;
    font-weight: 700;
    color: var(--foreground);
    margin-bottom: 0.35rem;
  }

  .fin-step-text {
    font-size: 0.95rem;
    line-height: 1.5;
    color: var(--muted-foreground);
  }

  /* CTA */
  .fin-cta {
    text-align: center;
  }

  .fin-btn {
    display: inline-flex;
    align-items: center;
    gap: 0.625rem;
    padding: 0.875rem 2.25rem;
    border-radius: 9999px;
    background: var(--brand-secondary);
    color: #fff;
    font-weight: 700;
    font-size: 0.95rem;
    text-decoration: none;
    transition: background 0.3s ease, transform 0.3s ease, box-shadow 0.3s ease;
    box-shadow: 0 4px 16px color-mix(in srgb, var(--brand-secondary) 25%, transparent);
  }
  .fin-btn:hover {
    background: var(--brand-highlight);
    color: #1a1a1a;
    transform: translateY(-2px);
    box-shadow: 0 8px 24px color-mix(in srgb, var(--brand-highlight) 30%, transparent);
  }
  .fin-btn svg {
    transition: transform 0.3s ease;
  }
  .fin-btn:hover svg {
    transform: translateX(4px);
  }

  /* Responsive */
  @media (max-width: 768px) {
    .fin-lists {
      grid-template-columns: 1fr;
    }
    .fin-steps {
      grid-template-columns: 1fr;
      max-width: 24rem;
    }
    .fin-step-line {
      display: none;
    }
  }
</style>
