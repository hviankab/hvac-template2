---
interface Props {
  title?: string;
  subtitle?: string;
  description?: string;
  phone?: string;
  email?: string;
  address?: string;
  hours?: string;
}

const {
  title = "We're Here to Help",
  subtitle = "Contact Us",
  description = "Have questions or need HVAC services? Fill out the form and our team will get back to you promptly. We're here to help with all your heating and cooling needs.",
  phone = "(+88)-123-4567",
  email = "support@gmail.com",
  address = "123 Coolvix Street, Chilltown",
  hours = "Mon-Sat: 8:00 AM - 8:00 PM"
} = Astro.props;
---

<section class="py-16 bg-white">
  <div class="container mx-auto px-4">
    <div class="grid lg:grid-cols-2 gap-8 max-w-7xl mx-auto">
      
      <!-- Left Column: Contact Form -->
      <div class="bg-gray-50 rounded-2xl p-6 lg:p-8">
        <!-- Header -->
        <div class="mb-6">
          <div class="flex items-center gap-2 mb-3">
            <svg class="w-5 h-5 text-[#1e3a8a]" fill="currentColor" viewBox="0 0 24 24">
              <path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm0 18c-4.41 0-8-3.59-8-8s3.59-8 8-8 8 3.59 8 8-3.59 8-8 8zm-1-13h2v6h-2zm0 8h2v2h-2z"/>
            </svg>
            <span class="text-[#1e3a8a] font-semibold text-sm uppercase tracking-wide">{subtitle}</span>
          </div>
          <h2 class="text-3xl font-bold text-black mb-3">{title}</h2>
          <p class="text-gray-600 leading-relaxed text-sm">{description}</p>
        </div>

        <!-- Form -->
        <form class="space-y-4">
          <!-- Full Name -->
          <div>
            <label class="block text-sm font-semibold text-gray-700 mb-1.5">Full Name</label>
            <input 
              type="text" 
              placeholder="David-Warner"
              class="w-full px-4 py-2.5 bg-white border border-gray-200 rounded-lg focus:outline-none focus:ring-2 focus:ring-[#1e3a8a] focus:border-transparent transition-all"
            />
          </div>

          <!-- Phone & Email -->
          <div class="grid md:grid-cols-2 gap-4">
            <div>
              <label class="block text-sm font-semibold text-gray-700 mb-1.5">Phone Number</label>
              <input 
                type="tel" 
                placeholder="+88-123-4567"
                class="w-full px-4 py-2.5 bg-white border border-gray-200 rounded-lg focus:outline-none focus:ring-2 focus:ring-[#1e3a8a] focus:border-transparent transition-all"
              />
            </div>
            <div>
              <label class="block text-sm font-semibold text-gray-700 mb-1.5">Email</label>
              <input 
                type="email" 
                placeholder="david@gmail.com"
                class="w-full px-4 py-2.5 bg-white border border-gray-200 rounded-lg focus:outline-none focus:ring-2 focus:ring-[#1e3a8a] focus:border-transparent transition-all"
              />
            </div>
          </div>

          <!-- Service Type -->
          <div>
            <label class="block text-sm font-semibold text-gray-700 mb-1.5">Service Type</label>
            <input 
              type="text" 
              placeholder="AC Repair, Installation"
              class="w-full px-4 py-2.5 bg-white border border-gray-200 rounded-lg focus:outline-none focus:ring-2 focus:ring-[#1e3a8a] focus:border-transparent transition-all"
            />
          </div>

          <!-- Message -->
          <div>
            <label class="block text-sm font-semibold text-gray-700 mb-1.5">Message</label>
            <textarea 
              rows="3"
              placeholder="Description of Issue"
              class="w-full px-4 py-2.5 bg-white border border-gray-200 rounded-lg focus:outline-none focus:ring-2 focus:ring-[#1e3a8a] focus:border-transparent transition-all resize-none"
            ></textarea>
          </div>

          <!-- Submit Button -->
          <button 
            type="submit"
            class="w-full bg-[#F7B32B] hover:bg-[#A9E5BB] text-black font-semibold py-3.5 px-6 rounded-full transition-all flex items-center justify-center gap-2 shadow-md hover:shadow-lg group"
            style="color: black;"
            onmouseenter="this.style.color='black';"
            onmouseleave="this.style.color='black';"
          >
            <span>Send Message</span>
            <svg class="w-4 h-4 transition-transform group-hover:translate-x-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3"/>
            </svg>
          </button>
        </form>
      </div>

      <!-- Right Column: Contact Information -->
      <div class="bg-gray-50 rounded-2xl p-6 lg:p-8">
        <h3 class="text-2xl font-bold text-black mb-3">Contact Information</h3>
        <p class="text-gray-600 mb-8 leading-relaxed text-sm">
          Reach out to us through any of the following channels. We're available to assist you with your HVAC needs.
        </p>

        <div class="space-y-6">
          <!-- Call Us -->
          <div class="flex items-start gap-4">
            <div class="relative">
              <div class="w-12 h-12 rounded-full bg-white flex items-center justify-center flex-shrink-0">
                <svg class="w-5 h-5 text-gray-700" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/>
                </svg>
              </div>
              <div class="absolute bottom-0 left-1/2 -translate-x-1/2 w-10 h-1 bg-[#F7B32B] rounded-full"></div>
            </div>
            <div>
              <h4 class="text-lg font-bold text-black mb-0.5">Call Us</h4>
              <p class="text-gray-600 text-sm">{phone}</p>
            </div>
          </div>

          <!-- Email Now -->
          <div class="flex items-start gap-4">
            <div class="relative">
              <div class="w-12 h-12 rounded-full bg-white flex items-center justify-center flex-shrink-0">
                <svg class="w-5 h-5 text-gray-700" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/>
                </svg>
              </div>
              <div class="absolute bottom-0 left-1/2 -translate-x-1/2 w-10 h-1 bg-[#F7B32B] rounded-full"></div>
            </div>
            <div>
              <h4 class="text-lg font-bold text-black mb-0.5">Email Now</h4>
              <p class="text-gray-600 text-sm">{email}</p>
            </div>
          </div>

          <!-- Address -->
          <div class="flex items-start gap-4">
            <div class="relative">
              <div class="w-12 h-12 rounded-full bg-white flex items-center justify-center flex-shrink-0">
                <svg class="w-5 h-5 text-gray-700" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/>
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/>
                </svg>
              </div>
              <div class="absolute bottom-0 left-1/2 -translate-x-1/2 w-10 h-1 bg-[#F7B32B] rounded-full"></div>
            </div>
            <div>
              <h4 class="text-lg font-bold text-black mb-0.5">Address</h4>
              <p class="text-gray-600 text-sm">{address}</p>
            </div>
          </div>

          <!-- Business Hours -->
          <div class="flex items-start gap-4">
            <div class="relative">
              <div class="w-12 h-12 rounded-full bg-white flex items-center justify-center flex-shrink-0">
                <svg class="w-5 h-5 text-gray-700" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/>
                </svg>
              </div>
              <div class="absolute bottom-0 left-1/2 -translate-x-1/2 w-10 h-1 bg-[#F7B32B] rounded-full"></div>
            </div>
            <div>
              <h4 class="text-lg font-bold text-black mb-0.5">Business Hours</h4>
              <p class="text-gray-600 text-sm">{hours}</p>
            </div>
          </div>
        </div>
      </div>

    </div>
  </div>
</section>
