---
import { getLocationText } from "@/config/site"

interface SocialLinks {
  linkedin?: string;
  twitter?: string;
  facebook?: string;
  instagram?: string;
}

interface TeamMember {
  name: string;
  role: string;
  image?: string;
  initials: string;
  social?: SocialLinks;
}

interface Props {
  badge?: string;
  title: string;
  description?: string;
  team: TeamMember[];
}

const { 
  badge = "OUR TEAM", 
  title: rawTitle, 
  description: rawDescription, 
  team 
} = Astro.props;

const title = getLocationText(rawTitle);
const description = rawDescription ? getLocationText(rawDescription) : undefined;
---

<section class="team-section">
  <div class="container mx-auto px-4">
    <!-- Header -->
    <div class="team-header" data-animate="fade-scale">
      <div class="eyebrow justify-center">
        <img src="/images/fan (2).png" alt="" aria-hidden="true" />
        <span>{badge}</span>
      </div>
      <h2 class="team-title">{title}</h2>
      {description && <p class="team-description" set:html={description} />}
    </div>

    <!-- Carousel -->
    <div class="team-carousel-wrapper">
      <!-- Left Arrow -->
      <button class="team-arrow team-arrow--prev" aria-label="Previous team members">
        <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M19 12H5M12 19l-7-7 7-7"/></svg>
      </button>

      <!-- Carousel -->
      <div class="team-carousel" data-animate="fade-up" data-animate-delay="200">
        <div class="team-viewport">
          <div class="team-track">
            {team.map((member) => (
              <div class="team-slide">
                <div class="team-card">
                  <div class="team-avatar">
                    {member.image ? (
                      <img src={member.image} alt={member.name} class="avatar-img" />
                    ) : (
                      <span class="avatar-initials">{member.initials}</span>
                    )}
                  </div>
                  <div class="team-info">
                    <h3 class="team-name">{member.name}</h3>
                    <p class="team-role">{member.role}</p>
                  </div>
                  
                  {member.social && (
                    <div class="team-social">
                      {member.social.linkedin && (
                        <a href={member.social.linkedin} target="_blank" rel="noopener noreferrer" class="social-link" aria-label={`${member.name} LinkedIn`}>
                          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="social-icon">
                            <path d="M19 0h-14c-2.761 0-5 2.239-5 5v14c0 2.761 2.239 5 5 5h14c2.762 0 5-2.239 5-5v-14c0-2.761-2.238-5-5-5zm-11 19h-3v-11h3v11zm-1.5-12.268c-.966 0-1.75-.79-1.75-1.764s.784-1.764 1.75-1.764 1.75.79 1.75 1.764-.783 1.764-1.75 1.764zm13.5 12.268h-3v-5.604c0-3.368-4-3.113-4 0v5.604h-3v-11h3v1.765c1.396-2.586 7-2.777 7 2.476v6.759z"/>
                          </svg>
                        </a>
                      )}
                      {member.social.twitter && (
                        <a href={member.social.twitter} target="_blank" rel="noopener noreferrer" class="social-link" aria-label={`${member.name} Twitter`}>
                          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="social-icon">
                            <path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/>
                          </svg>
                        </a>
                      )}
                      {member.social.facebook && (
                        <a href={member.social.facebook} target="_blank" rel="noopener noreferrer" class="social-link" aria-label={`${member.name} Facebook`}>
                          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="social-icon">
                            <path d="M9 8h-3v4h3v12h5v-12h3.642l.358-4h-4v-1.667c0-.955.192-1.333 1.115-1.333h2.885v-5h-3.808c-3.596 0-5.192 1.583-5.192 4.615v3.385z"/>
                          </svg>
                        </a>
                      )}
                      {member.social.instagram && (
                        <a href={member.social.instagram} target="_blank" rel="noopener noreferrer" class="social-link" aria-label={`${member.name} Instagram`}>
                          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="social-icon">
                            <path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073zm0 5.838c-3.403 0-6.162 2.759-6.162 6.162s2.759 6.163 6.162 6.163 6.162-2.759 6.162-6.163c0-3.403-2.759-6.162-6.162-6.162zm0 10.162c-2.209 0-4-1.79-4-4 0-2.209 1.791-4 4-4s4 1.791 4 4c0 2.21-1.791 4-4 4zm6.406-11.845c-.796 0-1.441.645-1.441 1.44s.645 1.44 1.441 1.44c.795 0 1.439-.645 1.439-1.44s-.644-1.44-1.439-1.44z"/>
                          </svg>
                        </a>
                      )}
                    </div>
                  )}
                </div>
              </div>
            ))}
          </div>
        </div>

        <!-- Dots at bottom center -->
        <div class="team-dots-bottom">
          <div class="team-dots"></div>
        </div>
      </div>

      <!-- Right Arrow -->
      <button class="team-arrow team-arrow--next" aria-label="Next team members">
        <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
      </button>
    </div>
  </div>
</section>

<style>
  .team-section {
    padding: 6rem 0;
    background: #f7f7f7;
  }

  .team-header {
    text-align: center;
    margin-bottom: 4rem;
  }

  .team-title {
    font-size: 2.5rem;
    font-weight: 700;
    color: #1e293b;
    line-height: 1.2;
    margin: 0 0 1rem 0;
  }

  .team-description {
    font-size: 1.125rem;
    line-height: 1.7;
    color: #1e293b;
    max-width: 48rem;
    margin: 0 auto;
  }

  /* Carousel Wrapper */
  .team-carousel-wrapper {
    position: relative;
    display: flex;
    align-items: center;
    gap: 2rem;
  }

  /* Carousel */
  .team-carousel {
    position: relative;
    overflow: visible;
    flex: 1;
    padding: 1.5rem 0;
    margin: -1.5rem 0;
  }

  /* Dots at bottom center */
  .team-dots-bottom {
    display: flex;
    justify-content: center;
    margin-top: 2rem;
    padding: 0.25rem 0;
  }

  .team-dots {
    display: flex;
    gap: 0.5rem;
    padding: 0.25rem;
  }
  .team-dots :global(button) {
    width: 0.625rem;
    height: 0.625rem;
    border-radius: 50%;
    border: none;
    background: #d1d5db;
    cursor: pointer;
    padding: 0;
    transition: background 0.3s ease, transform 0.3s ease;
  }
  .team-dots :global(button.is-active) {
    background: #dc2626;
    transform: scale(1.3);
  }

  .team-viewport {
    overflow: visible;
    cursor: grab;
    user-select: none;
    padding: 1.5rem 0;
  }
  .team-viewport:active {
    cursor: grabbing;
  }

  .team-track {
    display: flex;
    transition: transform 0.45s cubic-bezier(0.25, 0.1, 0.25, 1);
    will-change: transform;
  }
  .team-track.is-dragging {
    transition: none;
  }

  .team-slide {
    flex-shrink: 0;
    width: calc(100% / 4);
    padding: 0.5rem 0.625rem;
    box-sizing: border-box;
  }

  /* Team Card */
  .team-card {
    background: white;
    border-radius: 1rem;
    padding: 2rem 1.5rem;
    text-align: center;
    transition: all 0.3s ease;
    border: 1.5px solid #e2e8f0;
    box-shadow: 0 2px 8px rgba(0, 0, 0, 0.04);
  }

  .team-card:hover {
    transform: translateY(-4px);
    box-shadow: 0 8px 24px rgba(220, 38, 38, 0.12);
    border-color: #dc2626;
  }

  /* Avatar */
  .team-avatar {
    width: 120px;
    height: 120px;
    margin: 0 auto 1.5rem;
    border-radius: 50%;
    overflow: hidden;
    border: 4px solid #1e3a8a;
    box-shadow: 0 4px 12px rgba(30, 58, 138, 0.15);
    transition: all 0.3s ease;
  }

  .team-card:hover .team-avatar {
    border-color: #dc2626;
    box-shadow: 0 6px 16px rgba(220, 38, 38, 0.2);
  }

  .avatar-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .avatar-initials {
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    background: #1e3a8a;
    color: white;
    font-size: 2rem;
    font-weight: 700;
  }

  /* Team Info */
  .team-info {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .team-name {
    font-size: 1.25rem;
    font-weight: 700;
    color: #1e293b;
    margin: 0;
  }

  .team-role {
    font-size: 0.95rem;
    color: #1e293b;
    margin: 0;
    font-weight: 500;
  }

  /* Social Links */
  .team-social {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.75rem;
    margin-top: 1rem;
    padding-top: 1rem;
    border-top: 1px solid #e2e8f0;
  }

  .social-link {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 2rem;
    height: 2rem;
    border-radius: 50%;
    background: #f1f5f9;
    color: #1e293b;
    transition: all 0.3s ease;
    text-decoration: none;
  }

  .social-link:hover {
    background: #1e3a8a;
    color: white;
    transform: translateY(-2px);
  }

  .social-icon {
    width: 1rem;
    height: 1rem;
  }

  /* Controls - Arrows on sides */
  .team-arrow {
    width: 3.5rem;
    height: 3.5rem;
    border-radius: 50%;
    border: 2px solid #d1d5db;
    background: white;
    color: #1f2937;
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    transition: all 0.3s ease;
    flex-shrink: 0;
    z-index: 10;
  }
  .team-arrow:hover {
    background: #dc2626;
    color: white;
    border-color: #dc2626;
  }

  .team-arrow:disabled {
    opacity: 0.3;
    cursor: not-allowed;
  }

  /* Responsive */
  @media (max-width: 1024px) {
    .team-section {
      padding: 4rem 0;
    }

    .team-carousel-wrapper {
      gap: 1rem;
    }

    .team-arrow {
      width: 3rem;
      height: 3rem;
    }

    .team-slide {
      width: calc(100% / 3);
    }

    .team-title {
      font-size: 2rem;
    }
  }

  @media (max-width: 768px) {
    .team-section {
      padding: 3rem 0;
    }

    .team-slide {
      width: 50%;
    }

    .team-card {
      padding: 1.5rem 1rem;
    }

    .team-avatar {
      width: 100px;
      height: 100px;
    }

    .avatar-initials {
      font-size: 1.5rem;
    }

    .team-name {
      font-size: 1.125rem;
    }

    .team-role {
      font-size: 0.875rem;
    }

    .team-title {
      font-size: 1.75rem;
    }

    .team-description {
      font-size: 1rem;
    }
  }

  @media (max-width: 640px) {
    .team-carousel-wrapper {
      flex-direction: column;
      gap: 1.5rem;
    }

    .team-arrow {
      display: none;
    }

    .team-slide {
      width: 100%;
    }
  }
</style>

<script>
  function initTeamCarousel() {
    document.querySelectorAll<HTMLElement>('.team-carousel-wrapper').forEach((wrapper) => {
      const carousel = wrapper.querySelector<HTMLElement>('.team-carousel');
      const viewport = carousel?.querySelector<HTMLElement>('.team-viewport');
      const track = carousel?.querySelector<HTMLElement>('.team-track');
      const prevBtn = wrapper.querySelector<HTMLElement>('.team-arrow--prev');
      const nextBtn = wrapper.querySelector<HTMLElement>('.team-arrow--next');
      const dotsContainer = wrapper.querySelector<HTMLElement>('.team-dots');
      if (!viewport || !track || !prevBtn || !nextBtn || !dotsContainer) return;
      if (track.dataset.init === 'true') return;
      track.dataset.init = 'true';

      const slides = track.querySelectorAll<HTMLElement>('.team-slide');
      const totalSlides = slides.length;
      let currentIndex = 0;
      let perView = getPerView();

      function getPerView(): number {
        if (window.innerWidth <= 640) return 1;
        if (window.innerWidth <= 768) return 2;
        if (window.innerWidth <= 1024) return 3;
        return 4;
      }

      const maxIndex = () => Math.max(0, totalSlides - perView);

      // Build dots
      function buildDots() {
        dotsContainer!.innerHTML = '';
        const count = maxIndex() + 1;
        for (let i = 0; i < count; i++) {
          const dot = document.createElement('button');
          dot.setAttribute('aria-label', `Go to team group ${i + 1}`);
          if (i === currentIndex) dot.classList.add('is-active');
          dot.addEventListener('click', () => goTo(i));
          dotsContainer!.appendChild(dot);
        }
      }

      function updateDots() {
        const dots = dotsContainer!.querySelectorAll('button');
        dots.forEach((d, i) => d.classList.toggle('is-active', i === currentIndex));
      }

      function goTo(index: number) {
        currentIndex = Math.max(0, Math.min(index, maxIndex()));
        const slideWidth = slides[0].offsetWidth;
        track!.style.transform = `translateX(-${currentIndex * slideWidth}px)`;
        updateDots();
      }

      function next() { goTo(currentIndex + 1); }
      function prev() { goTo(currentIndex - 1); }

      prevBtn.addEventListener('click', prev);
      nextBtn.addEventListener('click', next);

      // Swipe support
      let startX = 0;
      let dragOffset = 0;
      let isDragging = false;
      let trackOffset = 0;

      viewport.addEventListener('mousedown', (e) => {
        isDragging = true; startX = e.clientX;
        trackOffset = currentIndex * slides[0].offsetWidth;
        track!.classList.add('is-dragging');
        e.preventDefault();
      });
      window.addEventListener('mousemove', (e) => {
        if (!isDragging) return;
        dragOffset = e.clientX - startX;
        track!.style.transform = `translateX(${-trackOffset + dragOffset}px)`;
      });
      window.addEventListener('mouseup', () => {
        if (!isDragging) return;
        isDragging = false;
        track!.classList.remove('is-dragging');
        if (dragOffset < -50) next();
        else if (dragOffset > 50) prev();
        else goTo(currentIndex);
        dragOffset = 0;
      });

      viewport.addEventListener('touchstart', (e) => {
        isDragging = true; startX = e.touches[0].clientX;
        trackOffset = currentIndex * slides[0].offsetWidth;
        track!.classList.add('is-dragging');
      }, { passive: true });
      viewport.addEventListener('touchmove', (e) => {
        if (!isDragging) return;
        dragOffset = e.touches[0].clientX - startX;
        track!.style.transform = `translateX(${-trackOffset + dragOffset}px)`;
      }, { passive: true });
      viewport.addEventListener('touchend', () => {
        if (!isDragging) return;
        isDragging = false;
        track!.classList.remove('is-dragging');
        if (dragOffset < -50) next();
        else if (dragOffset > 50) prev();
        else goTo(currentIndex);
        dragOffset = 0;
      }, { passive: true });

      // Resize
      window.addEventListener('resize', () => {
        perView = getPerView();
        buildDots();
        goTo(Math.min(currentIndex, maxIndex()));
      });

      buildDots();
      goTo(0);
    });
  }

  initTeamCarousel();
  document.addEventListener('astro:page-load', initTeamCarousel);
</script>
