---
interface Props {
  badge?: string;
  title: string;
  images?: string[];
  columns?: number;
}

const { badge = "Portfolio", title, images = [], columns = 4 } = Astro.props;

// Split images into two rows: top row gets first 4, bottom row gets the rest
const topRow = images.slice(0, 4);
const bottomRow = images.slice(4);
---

<section class="pf-section py-20 md:py-28">
  <div class="container mx-auto px-4">
    <div class="pf-header" data-animate="fade-scale">
      <div class="pf-badge-row">
        <span class="pf-accent-line"></span>
        <span class="pf-badge">{badge}</span>
        <span class="pf-accent-line"></span>
      </div>
      <h2 class="pf-title">{title}</h2>
    </div>

    {images.length > 0 ? (
      <div class="pf-gallery">
        <!-- Top row: 4 equal columns -->
        <div class="pf-row pf-row--top" data-animate-stagger>
          {topRow.map((img, i) => (
            <div class="pf-item">
              <img src={img} alt={`${title} - project ${i + 1}`} class="pf-img" width="400" height="300" loading="lazy" decoding="async" fetchpriority="low" />
              <div class="pf-hover">
                <div class="pf-hover-content">
                  <span class="pf-hover-label">Project {i + 1}</span>
                </div>
              </div>
            </div>
          ))}
        </div>

        <!-- Bottom row: wider cards for remaining images -->
        {bottomRow.length > 0 && (
          <div class="pf-row pf-row--bottom" style={`--pf-bottom-count: ${bottomRow.length}`} data-animate-stagger>
            {bottomRow.map((img, i) => (
              <div class="pf-item">
                <img src={img} alt={`${title} - project ${topRow.length + i + 1}`} class="pf-img" width="400" height="300" loading="lazy" decoding="async" fetchpriority="low" />
                <div class="pf-hover">
                  <div class="pf-hover-content">
                    <span class="pf-hover-label">Project {topRow.length + i + 1}</span>
                  </div>
                </div>
              </div>
            ))}
          </div>
        )}
      </div>
    ) : (
      <div class="pf-row pf-row--top" data-animate-stagger>
        {Array.from({ length: 8 }).map((_, i) => (
          <div class="pf-item pf-item--placeholder">
            <span>Project {i + 1}</span>
          </div>
        ))}
      </div>
    )}
  </div>
</section>

<style>
  .pf-section {
    background: var(--background);
  }

  .pf-header {
    text-align: center;
    margin-bottom: 3rem;
  }

  .pf-badge-row {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.75rem;
    margin-bottom: 1rem;
  }
  .pf-accent-line {
    width: 2.5rem;
    height: 3px;
    border-radius: 2px;
    background: var(--brand-secondary);
  }
  .pf-badge {
    font-size: 0.8rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--brand-secondary);
  }

  .pf-title {
    color: var(--foreground);
    line-height: 1.15;
  }

  .pf-gallery {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  /* Rows */
  .pf-row {
    display: grid;
    gap: 1rem;
  }

  .pf-row--top {
    grid-template-columns: repeat(4, 1fr);
  }

  .pf-row--bottom {
    grid-template-columns: repeat(var(--pf-bottom-count, 4), 1fr);
  }

  /* Items */
  .pf-item {
    position: relative;
    border-radius: 1rem;
    overflow: hidden;
    aspect-ratio: 4 / 3;
    cursor: pointer;
    box-shadow: 0 4px 16px rgba(0, 0, 0, 0.08);
    transition: box-shadow 0.35s ease;
  }
  .pf-item:hover {
    box-shadow: 0 12px 32px color-mix(in srgb, var(--brand-secondary) 18%, transparent);
  }

  .pf-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: transform 0.5s ease;
  }
  .pf-item:hover .pf-img {
    transform: scale(1.06);
  }

  /* Hover overlay */
  .pf-hover {
    position: absolute;
    inset: 0;
    background: linear-gradient(to top, color-mix(in srgb, var(--brand-secondary) 75%, transparent) 0%, transparent 60%);
    opacity: 0;
    transition: opacity 0.35s ease;
    display: flex;
    align-items: flex-end;
    padding: 1.25rem;
  }
  .pf-item:hover .pf-hover {
    opacity: 1;
  }

  .pf-hover-content {
    transform: translateY(8px);
    transition: transform 0.35s ease;
  }
  .pf-item:hover .pf-hover-content {
    transform: translateY(0);
  }

  .pf-hover-label {
    color: #fff;
    font-size: 0.9rem;
    font-weight: 700;
    letter-spacing: 0.03em;
  }

  /* Placeholder */
  .pf-item--placeholder {
    background: var(--card);
    border: 1.5px solid var(--border);
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--muted-foreground);
    font-size: 0.875rem;
  }

  /* Responsive */
  @media (max-width: 1024px) {
    .pf-row--top {
      grid-template-columns: repeat(2, 1fr);
    }
    .pf-row--bottom {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (max-width: 640px) {
    .pf-row--top,
    .pf-row--bottom {
      grid-template-columns: 1fr;
    }
    .pf-item {
      aspect-ratio: 16 / 10;
    }
  }
</style>
