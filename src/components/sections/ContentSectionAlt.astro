---
import { Image } from "astro:assets";
import { getLocationText } from "@/config/site"

interface FeatureItem {
  icon?: string;
  title: string;
  description: string;
}

interface Props {
  badge?: string;
  title: string;
  titleHighlight?: string;
  description: string;
  featuresTitle?: string;
  features?: FeatureItem[];
  buttonText?: string;
  buttonHref?: string;
  imagePosition?: "left" | "right";
  image?: string;
  imageAlt?: string;
}

const { 
  badge, 
  title: rawTitle, 
  titleHighlight: rawTitleHighlight,
  description: rawDescription, 
  featuresTitle,
  features: rawFeatures = [], 
  buttonText, 
  buttonHref,
  imagePosition = "left",
  image,
  imageAlt = "Section image"
} = Astro.props;

const title = getLocationText(rawTitle);
const titleHighlight = rawTitleHighlight ? getLocationText(rawTitleHighlight) : undefined;
const description = getLocationText(rawDescription);
const features = rawFeatures.map(f => ({
  ...f,
  title: getLocationText(f.title),
  description: getLocationText(f.description),
}));
---

<section class="py-16 md:py-24">
  <div class="container mx-auto px-4">
    {/* Header - centered above the two columns */}
    <div class="text-center mb-16 md:mb-20" data-animate="fade-up">
      {badge && (
        <div class="flex items-center justify-center gap-3 mb-4">
          <span class="w-10 h-[3px] rounded-full bg-brand-secondary"></span>
          <span class="text-sm font-bold uppercase text-brand-secondary" style="letter-spacing:0.1em;font-size:0.8rem;">{badge}</span>
          <span class="w-10 h-[3px] rounded-full bg-brand-secondary"></span>
        </div>
      )}
      <h2 class="text-3xl md:text-4xl lg:text-5xl font-bold">
        {title}{" "}
        {titleHighlight && (
          <span class="text-accent">{titleHighlight}</span>
        )}
      </h2>
      <p class="text-muted-foreground mt-6 max-w-3xl mx-auto text-xl" set:html={description} />
    </div>

    {/* Two column layout */}
    <div class={`grid md:grid-cols-2 gap-8 lg:gap-12 items-stretch max-w-6xl mx-auto ${imagePosition === "right" ? "" : ""}`}>
      {imagePosition === "left" && (
        <div class="rounded-lg overflow-hidden max-h-[480px]" data-animate="fade-right">
          {image ? (
            <Image src={image} alt={imageAlt} class="w-full h-full object-cover" width={665} height={480} format="webp" quality={75} loading="lazy" decoding="async" />
          ) : (
            <div class="aspect-video bg-muted flex items-center justify-center">
              <span class="text-muted-foreground text-sm">Image</span>
            </div>
          )}
        </div>
      )}

      <div class="space-y-8" data-animate="fade-up">
        {features.length > 0 && (
          <>
            {featuresTitle && (
              <h3 class="text-xl md:text-2xl font-bold mb-8">{featuresTitle}</h3>
            )}
            <ul class="space-y-8">
              {features.map((feature) => (
                <li class="flex gap-5">
                  <div class="flex-shrink-0 w-12 h-12 rounded-full bg-accent/10 text-accent flex items-center justify-center">
                    {feature.icon ? (
                      <span class="text-lg" set:html={feature.icon} />
                    ) : (
                      <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                        <path d="M22 11.08V12a10 10 0 1 1-5.93-9.14" />
                        <polyline points="22 4 12 14.01 9 11.01" />
                      </svg>
                    )}
                  </div>
                  <div class="flex-1">
                    <h4 class="font-semibold text-foreground text-lg mb-2">{feature.title}</h4>
                    <p class="text-muted-foreground text-base leading-relaxed" set:html={feature.description} />
                  </div>
                </li>
              ))}
            </ul>
          </>
        )}

        {buttonText && buttonHref && (
          <div class="pt-8">
            <a href={buttonHref} class="inline-flex items-center justify-center rounded-md bg-primary text-primary-foreground px-6 py-3 font-semibold hover:bg-brand-highlight hover:text-gray-900 transition-colors">
              {buttonText}
            </a>
          </div>
        )}
      </div>

      {imagePosition === "right" && (
        <div class="rounded-lg overflow-hidden max-h-[480px]" data-animate="fade-left">
          {image ? (
            <Image src={image} alt={imageAlt} class="w-full h-full object-cover" width={665} height={480} format="webp" quality={75} loading="lazy" decoding="async" />
          ) : (
            <div class="aspect-video bg-muted flex items-center justify-center">
              <span class="text-muted-foreground text-sm">Image</span>
            </div>
          )}
        </div>
      )}
    </div>
  </div>
</section>
