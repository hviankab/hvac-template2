---
import { siteConfig, getLocationText } from "@/config/site"

interface Props {
  title: string;
  description: string;
  calloutText: string;
  phone?: string;
  buttonText?: string;
  buttonHref?: string;
}

const { 
  title: rawTitle, 
  description: rawDescription, 
  calloutText: rawCalloutText,
  phone = siteConfig.contact.phoneFormatted,
  buttonText = "Sign Up Online",
  buttonHref = "/contact"
} = Astro.props;

const title = getLocationText(rawTitle);
const description = getLocationText(rawDescription);
const calloutText = getLocationText(rawCalloutText);
---

<section class="py-16 md:py-20 bg-primary text-primary-foreground">
  <div class="container mx-auto px-4">
    <div class="max-w-4xl mx-auto text-center" data-animate="fade-up">
      <h2 class="text-3xl md:text-4xl font-bold mb-4">{title}</h2>
      <p class="text-lg opacity-90 mb-8" set:html={description} />
      <p class="text-xl font-semibold mb-8">{calloutText}</p>
      <div class="flex flex-col sm:flex-row items-center justify-center gap-4">
        <a href={`tel:${phone}`} class="inline-flex items-center justify-center rounded-md bg-background text-foreground px-8 py-4 text-lg font-semibold hover:bg-brand-highlight hover:text-gray-900 transition-colors">
          Call {phone}
        </a>
        <a href={buttonHref} class="inline-flex items-center justify-center rounded-md border-2 border-primary-foreground px-8 py-4 text-lg font-semibold hover:bg-secondary hover:text-white hover:border-brand-highlight transition-colors">
          {buttonText}
        </a>
      </div>
    </div>
  </div>
</section>
