---
import { getLocationText } from "@/config/site"

interface Props {
  title: string;
  description?: string;
  buttonText?: string;
  buttonHref?: string;
  image?: string;
  imageAlt?: string;
}

const { 
  title: rawTitle, 
  description: rawDescription, 
  buttonText = "APPLY TODAY", 
  buttonHref = "/contact",
  image,
  imageAlt = "Join our team"
} = Astro.props;

const title = getLocationText(rawTitle);
const description = rawDescription ? getLocationText(rawDescription) : undefined;
---

<section class="py-16 md:py-24 bg-primary">
  <div class="container mx-auto px-4">
    <div class="grid md:grid-cols-2 gap-8 lg:gap-16 items-center">
      <div class="text-primary-foreground" data-animate="fade-right">
        <h2 class="text-3xl md:text-4xl font-bold mb-4">{title}</h2>
        {description && (
          <p class="text-primary-foreground/80 mb-6 max-w-lg" set:html={description} />
        )}
        <a 
          href={buttonHref} 
          class="inline-flex items-center justify-center rounded-md bg-accent text-accent-foreground px-6 py-3 font-semibold hover:bg-brand-highlight hover:text-gray-900 transition-colors"
        >
          {buttonText}
        </a>
      </div>
      <div class="flex justify-center md:justify-end" data-animate="fade-left">
        {image ? (
          <div class="relative w-full max-w-md">
            <div class="absolute inset-0 bg-gradient-to-br from-accent/20 to-transparent rounded-2xl blur-3xl -z-10"></div>
            <img 
              src={image} 
              alt={imageAlt} 
              class="rounded-2xl w-full object-cover shadow-2xl border-2 border-accent/30 hover:border-accent/60 transition-all duration-300 hover:shadow-accent/20 hover:shadow-2xl"
            />
          </div>
        ) : (
          <div class="relative w-full max-w-md">
            <div class="absolute inset-0 bg-gradient-to-br from-accent/20 to-transparent rounded-2xl blur-3xl -z-10"></div>
            <div class="aspect-square w-full bg-gradient-to-br from-primary-foreground/20 to-primary-foreground/5 rounded-2xl flex items-center justify-center border-2 border-primary-foreground/20">
              <span class="text-primary-foreground/50">Image</span>
            </div>
          </div>
        )}
      </div>
    </div>
  </div>
</section>
