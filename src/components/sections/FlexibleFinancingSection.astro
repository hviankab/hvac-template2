---
interface FinancingOption {
  icon: string;
  title: string;
  description: string;
}

interface Props {
  title: string;
  subtitle: string;
  options: FinancingOption[];
}

const {
  title,
  subtitle,
  options
} = Astro.props;
---

<section class="py-20 bg-[#f7f7f7]">
  <div class="container mx-auto px-4">
    <!-- Header -->
    <div class="text-center max-w-3xl mx-auto mb-16">
      <h2 class="text-4xl md:text-5xl font-bold text-black mb-4">
        {title}
      </h2>
      <p class="text-gray-600 text-lg">
        {subtitle}
      </p>
    </div>

    <!-- Financing Options Grid -->
    <div class="grid md:grid-cols-2 lg:grid-cols-4 gap-8 max-w-7xl mx-auto">
      {options.map((option) => (
        <div class="financing-card group">
          <div class="relative bg-white rounded-xl p-8 h-full border-3 border-[#1e3a8a] shadow-lg transition-all duration-300 hover:shadow-2xl">
            <!-- Icon -->
            <div class="inline-flex items-center justify-center w-16 h-16 rounded-full bg-[#1e3a8a] mb-6 transition-transform duration-300 group-hover:scale-110">
              <span class="text-white text-2xl font-bold">{option.icon}</span>
            </div>

            <!-- Title -->
            <h3 class="text-xl font-bold text-[#1e3a8a] mb-3 leading-tight">
              {option.title}
            </h3>

            <!-- Description -->
            <p class="text-gray-600 text-base leading-relaxed">
              {option.description}
            </p>

            <!-- Decorative gradient bar at bottom -->
            <div class="absolute bottom-0 left-0 w-full h-1 bg-gradient-to-r from-[#1e3a8a] to-[#dc2626] rounded-b-xl"></div>
          </div>
        </div>
      ))}
    </div>

    <!-- CTA Section -->
    <div class="text-center mt-16">
      <p class="text-gray-700 text-lg mb-6">
        Ready to get started with flexible financing?
      </p>
      <a
        href="/contact"
        class="financing-cta-btn inline-flex items-center gap-2 bg-[#F7B32B] text-gray-900 px-8 py-4 rounded-full font-semibold text-base transition-all shadow-lg"
      >
        Apply Now
        <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" viewBox="0 0 20 20" fill="currentColor">
          <path fill-rule="evenodd" d="M10.293 3.293a1 1 0 011.414 0l6 6a1 1 0 010 1.414l-6 6a1 1 0 01-1.414-1.414L14.586 11H3a1 1 0 110-2h11.586l-4.293-4.293a1 1 0 010-1.414z" clip-rule="evenodd" />
        </svg>
      </a>
    </div>
  </div>
</section>

<style>
  .financing-card {
    position: relative;
  }

  .financing-cta-btn:hover {
    background-color: #A9E5BB !important;
    color: #1a1a1a !important;
  }
</style>
