---
import { siteConfig, getLocationText } from "@/config/site"

interface Props {
  eyebrow?: string;
  title: string;
  subtitle?: string;
  buttonText?: string;
  buttonHref?: string;
  backgroundImage?: string;
}

const {
  eyebrow = "Professional HVAC Services",
  title: rawTitle,
  subtitle: rawSubtitle,
  buttonText = "Get a Free Quote",
  buttonHref = "/contact",
  backgroundImage = "/images/hvac-hero.jpg",
} = Astro.props;

const title = getLocationText(rawTitle);
const subtitle = rawSubtitle ? getLocationText(rawSubtitle) : undefined;
---

<section class="hero-page relative w-full min-h-[60vh] flex items-center overflow-hidden">

  <!-- Background image (single, no carousel) -->
  <div class="absolute inset-0 z-0">
    <div class="hero-bg" style={`background-image: url('${backgroundImage}');`}></div>
    <div class="absolute inset-0 bg-gradient-to-r from-black/80 via-black/55 to-black/30"></div>
  </div>

  <!-- Content (full width, no form on right) -->
  <div class="relative z-10 w-full py-16 md:py-20">
    <div class="container mx-auto px-4">

      <!-- Centered content -->
      <div class="max-w-4xl mx-auto text-center">
        <div class="eyebrow justify-center">
          <img src="/images/fan (2).png" alt="" aria-hidden="true" />
          <p class="text-white">
            {eyebrow}
          </p>
        </div>

        <h1 class="hero-h1 text-4xl md:text-6xl lg:text-7xl font-bold leading-tight text-white mb-7">
          {title}
        </h1>

        {subtitle && (
          <p class="hero-sub text-base md:text-xl text-white/80 mb-9 max-w-2xl mx-auto leading-relaxed">
            {subtitle}
          </p>
        )}

        <p class="text-sm font-semibold uppercase tracking-widest text-white mb-5">
          Let's Talk About Your Project
        </p>

        <div class="flex flex-col sm:flex-row items-center justify-center gap-5">
          <a
            href={buttonHref}
            class="hero-cta-btn inline-flex items-center gap-2 bg-brand-secondary text-gray-900 px-7 py-3.5 rounded-full font-semibold text-sm transition-all shadow-lg"
          >
            {buttonText}
          </a>
        </div>
      </div>

    </div>
  </div>
</section>

<style>
  .hero-page {
    min-height: 60vh;
  }

  .hero-bg {
    position: absolute;
    inset: 0;
    background-size: cover;
    background-position: center;
  }

  .eyebrow {
    animation: fadeUp 0.6s ease both;
  }
  .hero-h1 {
    animation: fadeUp 0.7s ease 0.1s both;
  }
  .hero-sub {
    animation: fadeUp 0.7s ease 0.2s both;
  }

  @keyframes fadeUp {
    from { opacity: 0; transform: translateY(20px); }
    to   { opacity: 1; transform: translateY(0); }
  }

  .hero-cta-btn:hover {
    background-color: #A9E5BB !important;
    color: #1a1a1a !important;
  }

  @media (prefers-reduced-motion: reduce) {
    .eyebrow, .hero-h1, .hero-sub { animation: none; }
  }
</style>
