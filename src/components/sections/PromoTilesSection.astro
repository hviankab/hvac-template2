---
import { siteConfig, getLocationText } from "@/config/site"

interface PromoTile {
  type: "maintenance" | "financing" | "emergency";
  tag?: string;
  title?: string;
  priceLabel?: string[];
  headline?: string[];
  subtext?: string;
  discount?: string;
  subheadline?: string[];
  phone?: string;
  buttonText: string;
  buttonHref?: string;
  bgImage?: string;
}

interface Props {
  tiles: PromoTile[];
}

const { tiles: rawTiles } = Astro.props;
const tiles = rawTiles.map(tile => ({
  ...tile,
  phone: tile.phone || siteConfig.contact.phoneFormatted,
  title: tile.title ? getLocationText(tile.title) : tile.title,
}));
---

<section class="promo-section py-16 md:py-24">
  <div class="container mx-auto px-4">
    <div class="promo-grid max-w-[1400px] mx-auto" data-animate-stagger>

      {tiles.map((tile, index) => (
        <div class={`promo-card promo-card--${tile.type} group rounded-3xl relative overflow-hidden ${index === 1 ? 'promo-card--featured' : ''}`}>
          
          {/* BG image */}
          {tile.bgImage && (
            <div class="absolute inset-0">
              <img
                src={tile.bgImage}
                alt=""
                aria-hidden="true"
                class="absolute inset-0 w-full h-full object-cover transition-transform duration-700 group-hover:scale-110"
              />
            </div>
          )}

          {/* Overlay */}
          <div class={`promo-overlay promo-overlay--${tile.type} absolute inset-0`} />

          {/* Decorative corner accent */}
          <div class="promo-corner absolute top-0 right-0 w-32 h-32 z-[1]" />

          {/* Content */}
          <div class="relative z-10 p-8 md:p-10 flex flex-col h-full">

            {/* Top row: tag + icon */}
            <div class="flex items-start justify-between mb-6">
              <div>
                {tile.tag && (
                  <span class="promo-tag inline-block text-sm font-bold px-4 py-1.5 rounded-full uppercase tracking-widest">
                    {tile.tag}
                  </span>
                )}
                {tile.type === "maintenance" && !tile.tag && (
                  <span class="promo-tag inline-block text-sm font-bold px-4 py-1.5 rounded-full uppercase tracking-widest">
                    Plan
                  </span>
                )}
                {tile.type === "financing" && !tile.tag && (
                  <span class="promo-tag inline-block text-sm font-bold px-4 py-1.5 rounded-full uppercase tracking-widest">
                    Financing
                  </span>
                )}
                {tile.type === "emergency" && !tile.tag && (
                  <span class="promo-tag inline-block text-sm font-bold px-4 py-1.5 rounded-full uppercase tracking-widest">
                    Special
                  </span>
                )}
              </div>
              <div class="promo-icon w-10 h-10 rounded-xl flex items-center justify-center flex-shrink-0">
                {tile.type === "maintenance" && (
                  <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <path d="M14.7 6.3a1 1 0 000 1.4l1.6 1.6a1 1 0 001.4 0l3.77-3.77a6 6 0 01-7.94 7.94l-6.91 6.91a2.12 2.12 0 01-3-3l6.91-6.91a6 6 0 017.94-7.94l-3.76 3.76z"/>
                  </svg>
                )}
                {tile.type === "financing" && (
                  <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <line x1="12" y1="1" x2="12" y2="23"/><path d="M17 5H9.5a3.5 3.5 0 000 7h5a3.5 3.5 0 010 7H6"/>
                  </svg>
                )}
                {tile.type === "emergency" && (
                  <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <polygon points="13 2 3 14 12 14 11 22 21 10 12 10 13 2"/>
                  </svg>
                )}
              </div>
            </div>

            {/* Main content - centered vertically */}
            <div class="flex-1 flex flex-col justify-center min-h-[200px]">

              {tile.type === "maintenance" && (
                <div class="text-center">
                  {tile.title && (
                    <h3 class="promo-heading text-lg md:text-xl uppercase tracking-wide mb-5 whitespace-pre-line leading-snug">
                      {tile.title}
                    </h3>
                  )}
                  {tile.priceLabel && (
                    <div class="promo-price-box rounded-2xl py-5 px-6 mb-4 mx-auto w-full max-w-[260px]">
                      <p class="text-base uppercase tracking-widest opacity-70 mb-1">{tile.priceLabel[0]}</p>
                      <p class="promo-price font-bold-extended leading-none my-1">{tile.priceLabel[1]}</p>
                      <p class="text-base uppercase tracking-widest opacity-70 mt-1">{tile.priceLabel[2]}</p>
                    </div>
                  )}
                  <p class="text-base text-white/60 mt-2">Priority scheduling included</p>
                </div>
              )}

              {tile.type === "financing" && (
                <div class="text-center">
                  {tile.headline && (
                    <div class="mb-3">
                      {tile.headline.map((line) => (
                        <p class="promo-headline font-bold-extended uppercase leading-none tracking-tight">
                          {line}
                        </p>
                      ))}
                    </div>
                  )}
                  {tile.subtext && (
                    <p class="text-base uppercase tracking-widest opacity-60 mb-5">{tile.subtext}</p>
                  )}
                  {/* Extra content for featured card */}
                  <div class="promo-features flex flex-col gap-3 mt-4 mb-2">
                    <div class="flex items-center gap-2.5 justify-center text-base text-white/85">
                      <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 text-white/60" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M20 6L9 17l-5-5"/></svg>
                      Quick approval process
                    </div>
                    <div class="flex items-center gap-2.5 justify-center text-base text-white/85">
                      <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 text-white/60" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M20 6L9 17l-5-5"/></svg>
                      Flexible payment options
                    </div>
                  </div>
                </div>
              )}

              {tile.type === "emergency" && (
                <div class="text-center">
                  {tile.discount && (
                    <p class="promo-discount font-bold-extended leading-none mb-1">{tile.discount}</p>
                  )}
                  {tile.subheadline && (
                    <div class="mb-4">
                      {tile.subheadline.map((line) => (
                        <p class="text-lg md:text-xl font-bold uppercase tracking-wide opacity-90">{line}</p>
                      ))}
                    </div>
                  )}
                  {/* Extra details */}
                  <div class="promo-extras rounded-xl py-4 px-5 mb-2 mx-auto max-w-[280px]">
                    <div class="flex items-center justify-between text-base text-white/80 mb-2.5">
                      <span>System inspection</span>
                      <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 text-white/60" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M20 6L9 17l-5-5"/></svg>
                    </div>
                    <div class="flex items-center justify-between text-base text-white/80 mb-2.5">
                      <span>Filter replacement</span>
                      <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 text-white/60" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M20 6L9 17l-5-5"/></svg>
                    </div>
                    <div class="flex items-center justify-between text-base text-white/80">
                      <span>Performance report</span>
                      <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 text-white/60" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M20 6L9 17l-5-5"/></svg>
                    </div>
                  </div>
                  <p class="text-base text-white/50 mt-3">Limited time offer</p>
                </div>
              )}
            </div>

            {/* CTA */}
            <div class="flex flex-col items-center gap-3 pt-6">
              <a
                href={tile.buttonHref || "/contact"}
                class={`promo-btn promo-btn--${tile.type} inline-flex items-center justify-center gap-2 w-full rounded-full px-6 py-3.5 font-semibold text-base uppercase tracking-wide transition-all`}
                aria-label={`${tile.buttonText} - ${tile.title || tile.headline?.join(' ') || tile.discount || 'promo'}`}
              >
                {tile.buttonText}
                <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 transition-transform group-hover:translate-x-1" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
                  <path d="M5 12h14M12 5l7 7-7 7"/>
                </svg>
              </a>
              <a
                href={`tel:${tile.phone.replace(/[^0-9]/g, '')}`}
                class="promo-phone inline-flex items-center gap-2 text-base text-white/60 hover:text-brand-highlight transition-colors"
              >
                <svg xmlns="http://www.w3.org/2000/svg" class="w-3.5 h-3.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                  <path d="M22 16.92v3a2 2 0 01-2.18 2 19.79 19.79 0 01-8.63-3.07 19.5 19.5 0 01-6-6 19.79 19.79 0 01-3.07-8.67A2 2 0 014.11 2h3a2 2 0 012 1.72c.127.96.361 1.903.7 2.81a2 2 0 01-.45 2.11L8.09 9.91a16 16 0 006 6l1.27-1.27a2 2 0 012.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0122 16.92z"/>
                </svg>
                {tile.phone}
              </a>
            </div>
          </div>
        </div>
      ))}

    </div>
  </div>
</section>

<style>
  .promo-section {
    background: var(--background);
  }

  /* Grid with staggered middle card */
  .promo-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1.5rem;
    align-items: stretch;
  }

  @media (min-width: 768px) {
    .promo-grid {
      grid-template-columns: repeat(3, 1fr);
    }
    .promo-card--featured {
      transform: none;
    }
    .promo-card--featured:hover {
      transform: translateY(-6px);
    }
  }

  .promo-card {
    border: 2px solid rgba(255, 255, 255, 0.15);
    box-shadow: 0 8px 32px rgba(0, 0, 0, 0.08);
    transition: transform 0.4s ease, box-shadow 0.4s ease;
    color: #fff;
    isolation: isolate;
    overflow: hidden;
    border-radius: 1.5rem;
    -webkit-mask-image: -webkit-radial-gradient(white, black);
  }

  .promo-card:hover {
    transform: translateY(-6px);
    box-shadow: 0 20px 48px rgba(0, 0, 0, 0.15);
  }

  /* Corner decorative accent */
  .promo-card--maintenance .promo-corner {
    background: radial-gradient(circle at top right, rgba(236, 233, 249, 0.12) 0%, transparent 70%);
  }
  .promo-card--financing .promo-corner {
    background: radial-gradient(circle at top right, rgba(255, 255, 255, 0.1) 0%, transparent 70%);
  }
  .promo-card--emergency .promo-corner {
    background: radial-gradient(circle at top right, rgba(236, 233, 249, 0.1) 0%, transparent 70%);
  }

  /* Overlays */
  .promo-overlay--maintenance {
    background: linear-gradient(160deg, rgba(0, 0, 1, 0.92) 0%, rgba(0, 0, 1, 0.8) 100%);
  }
  .promo-overlay--financing {
    background: linear-gradient(160deg, color-mix(in srgb, var(--brand-secondary) 94%, transparent) 0%, color-mix(in srgb, var(--brand-secondary) 80%, transparent) 100%);
  }
  .promo-overlay--emergency {
    background: linear-gradient(160deg, rgba(34, 100, 172, 0.94) 0%, rgba(34, 100, 172, 0.8) 100%);
  }

  /* Solid fallback when no bg image */
  .promo-card--maintenance:not(:has(img)) .promo-overlay--maintenance {
    background: var(--brand-primary);
  }
  .promo-card--financing:not(:has(img)) .promo-overlay--financing {
    background: var(--brand-secondary);
  }
  .promo-card--emergency:not(:has(img)) .promo-overlay--emergency {
    background: var(--brand-accent-secondary);
  }

  /* Icon box */
  .promo-icon {
    background: rgba(255, 255, 255, 0.1);
    color: #fff;
    border: 1px solid rgba(255, 255, 255, 0.12);
  }

  /* Tag */
  .promo-tag {
    background: rgba(255, 255, 255, 0.12);
    color: #fff;
    border: 1px solid rgba(255, 255, 255, 0.15);
  }

  /* Typography */
  .promo-heading {
    font-family: 'Poppins', system-ui, sans-serif;
    font-weight: 700;
    color: #fff;
  }

  .promo-price {
    font-size: clamp(2.5rem, 5vw, 3.5rem);
    color: var(--brand-tertiary);
  }

  .promo-headline {
    font-size: clamp(1.6rem, 4vw, 2.2rem);
    color: #fff;
  }

  .promo-discount {
    font-size: clamp(3rem, 6vw, 4.5rem);
    color: #fff;
  }

  .promo-price-box {
    background: rgba(255, 255, 255, 0.06);
    border: 1px solid rgba(255, 255, 255, 0.1);
  }

  .promo-extras {
    background: rgba(255, 255, 255, 0.06);
    border: 1px solid rgba(255, 255, 255, 0.08);
  }

  /* Buttons */
  .promo-btn--maintenance {
    background: var(--brand-tertiary);
    color: var(--brand-primary);
  }
  .promo-btn--maintenance:hover {
    background: var(--brand-highlight);
    color: #1a1a1a;
    box-shadow: 0 4px 16px color-mix(in srgb, var(--brand-highlight) 40%, transparent);
    transform: translateY(-2px);
  }

  .promo-btn--financing {
    background: #fff;
    color: var(--brand-secondary);
  }
  .promo-btn--financing:hover {
    background: var(--brand-highlight);
    color: #1a1a1a;
    box-shadow: 0 4px 16px color-mix(in srgb, var(--brand-highlight) 40%, transparent);
    transform: translateY(-2px);
  }

  .promo-btn--emergency {
    background: #fff;
    color: var(--brand-accent-secondary);
  }
  .promo-btn--emergency:hover {
    background: var(--brand-highlight);
    color: #1a1a1a;
    box-shadow: 0 4px 16px color-mix(in srgb, var(--brand-highlight) 40%, transparent);
    transform: translateY(-2px);
  }

  /* Featured card extra styling */
  .promo-card--featured {
    box-shadow: 0 12px 40px color-mix(in srgb, var(--brand-secondary) 20%, transparent);
  }
  .promo-card--featured:hover {
    box-shadow: 0 24px 56px color-mix(in srgb, var(--brand-secondary) 25%, transparent);
  }

  @media (max-width: 768px) {
    .promo-card {
      min-height: 340px;
    }
  }
</style>
