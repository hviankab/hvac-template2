---
import { getLocationText } from "@/config/site"

interface Testimonial {
  name: string;
  initials: string;
  date: string;
  rating: number;
  content: string;
}

interface Props {
  badge?: string;
  title: string;
  description?: string;
  testimonials: Testimonial[];
}

const { badge = "Testimonials", title: rawTitle, description: rawDescription, testimonials: rawTestimonials } = Astro.props;

const title = getLocationText(rawTitle);
const description = rawDescription ? getLocationText(rawDescription) : undefined;
const testimonials = rawTestimonials.map(t => ({ ...t, content: getLocationText(t.content) }));
---

<section class="tm-section py-20 md:py-28">
  <div class="container mx-auto px-4">
    <!-- Header with arrows -->
    <div class="tm-top" data-animate="fade-scale">
      <div class="tm-header">
        <div class="tm-badge-row">
          <span class="tm-accent-line"></span>
          <span class="tm-badge">{badge}</span>
          <span class="tm-accent-line"></span>
        </div>
        <h2 class="tm-title">{title}</h2>
        {description && <p class="tm-desc" set:html={description} />}
      </div>
    </div>

    <!-- Carousel -->
    <div class="tm-carousel" data-animate="fade-up" data-animate-delay="200">
      <div class="tm-viewport">
        <div class="tm-track">
          {testimonials.map((t) => (
            <div class="tm-slide">
              <div class="tm-card">
                <div class="tm-quote-icon" aria-hidden="true">
                  <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-6" viewBox="0 0 24 24" fill="currentColor"><path d="M11.3 2.6C6.1 5.1 3 9.7 3 15v6h8v-8H7c0-3.3 1.7-6 4.6-7.4L11.3 2.6zM23.3 2.6C18.1 5.1 15 9.7 15 15v6h8v-8h-4c0-3.3 1.7-6 4.6-7.4L23.3 2.6z"/></svg>
                </div>

                <div class="tm-stars" role="img" aria-label={`${t.rating} out of 5 stars`}>
                  {Array.from({ length: 5 }).map((_, i) => (
                    <svg xmlns="http://www.w3.org/2000/svg" class:list={["tm-star", { "tm-star--filled": i < t.rating }]} viewBox="0 0 24 24" fill="currentColor" width="18" height="18">
                      <path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/>
                    </svg>
                  ))}
                </div>

                <p class="tm-content" set:html={t.content} />

                <div class="tm-author">
                  <div class="tm-avatar"><span>{t.initials}</span></div>
                  <div class="tm-author-info">
                    <span class="tm-name">{t.name}</span>
                    <span class="tm-date">{t.date}</span>
                  </div>
                </div>
              </div>
            </div>
          ))}
        </div>
      </div>

      <!-- Controls -->
      <div class="tm-controls">
        <button class="tm-arrow tm-arrow--prev" aria-label="Previous testimonials">
          <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M19 12H5M12 19l-7-7 7-7"/></svg>
        </button>
        <div class="tm-dots"></div>
        <button class="tm-arrow tm-arrow--next" aria-label="Next testimonials">
          <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
        </button>
      </div>
    </div>
  </div>
</section>

<style>
  .tm-section {
    background: var(--background);
  }

  .tm-top {
    margin-bottom: 3rem;
  }

  .tm-header {
    text-align: center;
  }

  .tm-badge-row {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.75rem;
    margin-bottom: 1rem;
  }
  .tm-accent-line {
    width: 2.5rem;
    height: 3px;
    border-radius: 2px;
    background: var(--brand-secondary);
  }
  .tm-badge {
    font-size: 0.8rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--brand-secondary);
  }
  .tm-title {
    color: var(--foreground);
    line-height: 1.15;
    margin-bottom: 1rem;
  }
  .tm-desc {
    font-size: 1.125rem;
    line-height: 1.7;
    color: var(--muted-foreground);
    max-width: 48rem;
    margin: 0 auto;
  }

  /* Carousel */
  .tm-carousel {
    position: relative;
    overflow: hidden;
  }

  .tm-viewport {
    overflow: visible;
    cursor: grab;
    user-select: none;
    padding-bottom: 2rem;
  }
  .tm-viewport:active {
    cursor: grabbing;
  }

  .tm-track {
    display: flex;
    transition: transform 0.45s cubic-bezier(0.25, 0.1, 0.25, 1);
    will-change: transform;
  }
  .tm-track.is-dragging {
    transition: none;
  }

  .tm-slide {
    flex-shrink: 0;
    width: calc(100% / 3);
    padding: 0 0.625rem;
    box-sizing: border-box;
  }

  /* Card */
  .tm-card {
    background: var(--card);
    border: 1.5px solid var(--border);
    border-radius: 1rem;
    padding: 2rem;
    min-height: 360px;
    height: 100%;
    display: flex;
    flex-direction: column;
    transition: border-color 0.3s ease, box-shadow 0.3s ease;
  }
  .tm-card:hover {
    border-color: var(--brand-secondary);
    box-shadow: 0 12px 32px color-mix(in srgb, var(--brand-secondary) 10%, transparent);
  }

  .tm-quote-icon {
    width: 2.5rem;
    height: 2.5rem;
    border-radius: 0.625rem;
    background: var(--brand-secondary);
    color: #fff;
    display: flex;
    align-items: center;
    justify-content: center;
    margin-bottom: 1.25rem;
  }

  .tm-stars {
    display: flex;
    gap: 2px;
    margin-bottom: 1rem;
  }
  .tm-star { color: var(--border); }
  .tm-star--filled { color: #f59e0b; }

  .tm-content {
    font-size: 1rem;
    line-height: 1.65;
    color: var(--muted-foreground);
    flex: 1;
    margin-bottom: 1.5rem;
  }

  .tm-author {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    padding-top: 1.25rem;
    border-top: 1px solid var(--border);
  }
  .tm-avatar {
    width: 2.75rem;
    height: 2.75rem;
    border-radius: 50%;
    background: var(--brand-secondary);
    color: #fff;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 0.85rem;
    font-weight: 700;
    flex-shrink: 0;
  }
  .tm-author-info { display: flex; flex-direction: column; }
  .tm-name { font-size: 0.95rem; font-weight: 700; color: var(--foreground); }
  .tm-date { font-size: 0.8rem; color: var(--muted-foreground); }

  /* Controls */
  .tm-controls {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 1rem;
    margin-top: 2rem;
  }

  .tm-arrow {
    width: 2.75rem;
    height: 2.75rem;
    border-radius: 50%;
    border: 1.5px solid var(--border);
    background: var(--card);
    color: var(--foreground);
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    transition: background 0.3s ease, color 0.3s ease, border-color 0.3s ease;
  }
  .tm-arrow:hover {
    background: var(--brand-secondary);
    color: #fff;
    border-color: var(--brand-secondary);
  }

  .tm-dots {
    display: flex;
    gap: 0.5rem;
  }
  .tm-dots :global(button) {
    width: 0.625rem;
    height: 0.625rem;
    border-radius: 50%;
    border: none;
    background: var(--border);
    cursor: pointer;
    padding: 0;
    transition: background 0.3s ease, transform 0.3s ease;
  }
  .tm-dots :global(button.is-active) {
    background: var(--brand-secondary);
    transform: scale(1.3);
  }

  /* Responsive */
  @media (max-width: 1024px) {
    .tm-slide {
      width: 50%;
    }
  }
  @media (max-width: 640px) {
    .tm-slide {
      width: 100%;
    }
  }
</style>

<script>
  function initTestimonialsCarousel() {
    document.querySelectorAll<HTMLElement>('.tm-carousel').forEach((carousel) => {
      const viewport = carousel.querySelector<HTMLElement>('.tm-viewport');
      const track = carousel.querySelector<HTMLElement>('.tm-track');
      const prevBtn = carousel.querySelector<HTMLElement>('.tm-arrow--prev');
      const nextBtn = carousel.querySelector<HTMLElement>('.tm-arrow--next');
      const dotsContainer = carousel.querySelector<HTMLElement>('.tm-dots');
      if (!viewport || !track || !prevBtn || !nextBtn || !dotsContainer) return;
      if (track.dataset.init === 'true') return;
      track.dataset.init = 'true';

      const slides = track.querySelectorAll<HTMLElement>('.tm-slide');
      const totalSlides = slides.length;
      let currentIndex = 0;
      let perView = getPerView();

      function getPerView(): number {
        if (window.innerWidth <= 640) return 1;
        if (window.innerWidth <= 1024) return 2;
        return 3;
      }

      const maxIndex = () => Math.max(0, totalSlides - perView);

      // Build dots
      function buildDots() {
        dotsContainer!.innerHTML = '';
        const count = maxIndex() + 1;
        for (let i = 0; i < count; i++) {
          const dot = document.createElement('button');
          dot.setAttribute('aria-label', `Go to slide group ${i + 1}`);
          if (i === currentIndex) dot.classList.add('is-active');
          dot.addEventListener('click', () => goTo(i));
          dotsContainer!.appendChild(dot);
        }
      }

      function updateDots() {
        const dots = dotsContainer!.querySelectorAll('button');
        dots.forEach((d, i) => d.classList.toggle('is-active', i === currentIndex));
      }

      function goTo(index: number) {
        currentIndex = Math.max(0, Math.min(index, maxIndex()));
        const slideWidth = slides[0].offsetWidth;
        track!.style.transform = `translateX(-${currentIndex * slideWidth}px)`;
        updateDots();
      }

      function next() { goTo(currentIndex + 1); }
      function prev() { goTo(currentIndex - 1); }

      prevBtn.addEventListener('click', prev);
      nextBtn.addEventListener('click', next);

      // Swipe support
      let startX = 0;
      let dragOffset = 0;
      let isDragging = false;
      let trackOffset = 0;

      viewport.addEventListener('mousedown', (e) => {
        isDragging = true; startX = e.clientX;
        trackOffset = currentIndex * slides[0].offsetWidth;
        track!.classList.add('is-dragging');
        e.preventDefault();
      });
      window.addEventListener('mousemove', (e) => {
        if (!isDragging) return;
        dragOffset = e.clientX - startX;
        track!.style.transform = `translateX(${-trackOffset + dragOffset}px)`;
      });
      window.addEventListener('mouseup', () => {
        if (!isDragging) return;
        isDragging = false;
        track!.classList.remove('is-dragging');
        if (dragOffset < -50) next();
        else if (dragOffset > 50) prev();
        else goTo(currentIndex);
        dragOffset = 0;
      });

      viewport.addEventListener('touchstart', (e) => {
        isDragging = true; startX = e.touches[0].clientX;
        trackOffset = currentIndex * slides[0].offsetWidth;
        track!.classList.add('is-dragging');
      }, { passive: true });
      viewport.addEventListener('touchmove', (e) => {
        if (!isDragging) return;
        dragOffset = e.touches[0].clientX - startX;
        track!.style.transform = `translateX(${-trackOffset + dragOffset}px)`;
      }, { passive: true });
      viewport.addEventListener('touchend', () => {
        if (!isDragging) return;
        isDragging = false;
        track!.classList.remove('is-dragging');
        if (dragOffset < -50) next();
        else if (dragOffset > 50) prev();
        else goTo(currentIndex);
        dragOffset = 0;
      }, { passive: true });

      // Resize
      window.addEventListener('resize', () => {
        perView = getPerView();
        buildDots();
        goTo(Math.min(currentIndex, maxIndex()));
      });

      buildDots();
      goTo(0);
    });
  }

  initTestimonialsCarousel();
  document.addEventListener('astro:page-load', initTestimonialsCarousel);
</script>
