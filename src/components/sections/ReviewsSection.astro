---
import { getLocationText } from "@/config/site"

interface Review {
  name: string;
  time: string;
  content: string;
  readMoreHref?: string;
}

interface Props {
  badge?: string;
  title: string;
  description?: string;
  reviews: Review[];
  verifiedBy?: string;
}

const { badge = "GOOGLE REVIEW", title: rawTitle, description: rawDescription, reviews: rawReviews, verifiedBy = "Verified by Trustindex" } = Astro.props;

const title = getLocationText(rawTitle);
const description = rawDescription ? getLocationText(rawDescription) : undefined;
const reviews = rawReviews.map(r => ({ ...r, content: getLocationText(r.content) }));
---

<section class="rv-section py-20 md:py-28">
  <div class="container mx-auto px-4">
    
    <!-- Header -->
    <div class="text-center mb-12" data-animate="fade-up">
      <div class="rv-badge-row">
        <span class="rv-accent-line"></span>
        <span class="rv-badge-text">{badge}</span>
        <span class="rv-accent-line"></span>
      </div>
      <h2 class="mb-4">{title}</h2>
      {description && <p class="text-lg text-muted-foreground max-w-3xl mx-auto" set:html={description} />}
    </div>

    <!-- Carousel -->
    <div class="rv-carousel">
      <div class="rv-viewport">
        <div class="rv-track">
          {reviews.map((review) => (
            <div class="rv-slide">
              <div class="rv-card">
                <!-- Author -->
                <div class="flex items-center gap-3 mb-4">
                  <div class="rv-avatar">
                    <span>{review.name.split(' ').map(n => n[0]).join('')}</span>
                  </div>
                  <div>
                    <p class="text-base font-bold">{review.name}</p>
                    <p class="text-sm text-muted-foreground">{review.time}</p>
                  </div>
                </div>

                <!-- Stars -->
                <div class="flex gap-0.5 mb-4">
                  {Array.from({ length: 5 }).map(() => (
                    <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 text-amber-400" viewBox="0 0 24 24" fill="currentColor">
                      <path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/>
                    </svg>
                  ))}
                </div>

                <!-- Content -->
                <p class="text-base text-muted-foreground leading-relaxed mb-4 line-clamp-4" set:html={review.content} />


              </div>
            </div>
          ))}
        </div>
      </div>

      <!-- Controls -->
      <div class="rv-controls">
        <button class="rv-arrow rv-arrow--prev" aria-label="Previous reviews">
          <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M19 12H5M12 19l-7-7 7-7"/></svg>
        </button>
        <div class="rv-dots"></div>
        <button class="rv-arrow rv-arrow--next" aria-label="Next reviews">
          <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
        </button>
      </div>
    </div>


  </div>
</section>

<style>
  .rv-section {
    background: var(--brand-tertiary);
    overflow: hidden;
  }

  .rv-badge-row {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.75rem;
    margin-bottom: 1rem;
  }
  .rv-accent-line {
    width: 2.5rem;
    height: 3px;
    border-radius: 2px;
    background: var(--brand-secondary);
  }
  .rv-badge-text {
    font-size: 0.8rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--brand-secondary);
  }

  /* Carousel */
  .rv-viewport {
    overflow: hidden;
    cursor: grab;
    user-select: none;
  }
  .rv-viewport:active {
    cursor: grabbing;
  }

  .rv-track {
    display: flex;
    transition: transform 0.5s cubic-bezier(0.25, 0.1, 0.25, 1);
    will-change: transform;
  }
  .rv-track.is-dragging {
    transition: none;
  }

  .rv-slide {
    flex-shrink: 0;
    width: calc(100% / 4);
    padding: 0 0.5rem;
    box-sizing: border-box;
  }

  /* Card */
  .rv-card {
    background: var(--card);
    border: 2px solid white;
    border-radius: 1.25rem;
    padding: 1.75rem;
    height: 100%;
    display: flex;
    flex-direction: column;
    transition: border-color 0.3s ease, box-shadow 0.3s ease, transform 0.3s ease;
    box-shadow: 0 4px 16px rgba(0, 0, 0, 0.04);
  }
  .rv-card:hover {
    border-color: var(--brand-highlight);
    box-shadow: 0 12px 32px color-mix(in srgb, var(--brand-highlight) 15%, transparent);
  }

  .rv-avatar {
    width: 2.75rem;
    height: 2.75rem;
    border-radius: 50%;
    background: var(--brand-secondary);
    color: #fff;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 0.85rem;
    font-weight: 700;
    flex-shrink: 0;
  }

  .rv-readmore {
    color: var(--brand-secondary);
    transition: gap 0.2s ease;
  }
  .rv-readmore:hover {
    gap: 0.5rem;
  }

  /* Controls */
  .rv-controls {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 1rem;
    margin-top: 2.5rem;
  }

  .rv-arrow {
    width: 2.75rem;
    height: 2.75rem;
    border-radius: 50%;
    border: 2px solid var(--border);
    background: var(--card);
    color: var(--foreground);
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    transition: background 0.3s ease, color 0.3s ease, border-color 0.3s ease;
  }
  .rv-arrow:hover {
    background: var(--brand-highlight);
    color: #1a1a1a;
    border-color: var(--brand-highlight);
  }

  .rv-dots {
    display: flex;
    gap: 0.5rem;
  }
  .rv-dots :global(button) {
    width: 0.5rem;
    height: 0.5rem;
    border-radius: 50%;
    border: none;
    background: var(--border);
    cursor: pointer;
    padding: 0;
    transition: background 0.3s ease, transform 0.3s ease, width 0.3s ease, border-radius 0.3s ease;
  }
  .rv-dots :global(button.is-active) {
    background: var(--brand-secondary);
    width: 1.5rem;
    border-radius: 0.25rem;
  }

  /* Responsive */
  @media (max-width: 1024px) {
    .rv-slide { width: 50%; }
  }
  @media (max-width: 640px) {
    .rv-slide { width: 100%; }
  }
</style>

<script>
  function initReviewsCarousel() {
    document.querySelectorAll<HTMLElement>('.rv-carousel').forEach((carousel) => {
      const viewport = carousel.querySelector<HTMLElement>('.rv-viewport');
      const track = carousel.querySelector<HTMLElement>('.rv-track');
      const prevBtn = carousel.querySelector<HTMLElement>('.rv-arrow--prev');
      const nextBtn = carousel.querySelector<HTMLElement>('.rv-arrow--next');
      const dotsContainer = carousel.querySelector<HTMLElement>('.rv-dots');
      if (!viewport || !track || !prevBtn || !nextBtn || !dotsContainer) return;
      if (track.dataset.rvInit === 'true') return;
      track.dataset.rvInit = 'true';

      const slides = track.querySelectorAll<HTMLElement>('.rv-slide');
      const totalSlides = slides.length;
      let currentIndex = 0;
      let perView = getPerView();
      let autoplayTimer: ReturnType<typeof setInterval> | null = null;

      function getPerView(): number {
        if (window.innerWidth <= 640) return 1;
        if (window.innerWidth <= 1024) return 2;
        return 4;
      }

      const maxIndex = () => Math.max(0, totalSlides - perView);

      function buildDots() {
        dotsContainer!.innerHTML = '';
        const count = maxIndex() + 1;
        for (let i = 0; i < count; i++) {
          const dot = document.createElement('button');
          dot.setAttribute('aria-label', `Go to review group ${i + 1}`);
          if (i === currentIndex) dot.classList.add('is-active');
          dot.addEventListener('click', () => { goTo(i); resetAutoplay(); });
          dotsContainer!.appendChild(dot);
        }
      }

      function updateDots() {
        dotsContainer!.querySelectorAll('button').forEach((d, i) =>
          d.classList.toggle('is-active', i === currentIndex)
        );
      }

      function goTo(index: number) {
        currentIndex = Math.max(0, Math.min(index, maxIndex()));
        const slideWidth = slides[0].offsetWidth;
        track!.style.transform = `translateX(-${currentIndex * slideWidth}px)`;
        updateDots();
      }

      function next() { goTo(currentIndex >= maxIndex() ? 0 : currentIndex + 1); }
      function prev() { goTo(currentIndex <= 0 ? maxIndex() : currentIndex - 1); }

      function startAutoplay() {
        stopAutoplay();
        autoplayTimer = setInterval(next, 5000);
      }
      function stopAutoplay() {
        if (autoplayTimer) { clearInterval(autoplayTimer); autoplayTimer = null; }
      }
      function resetAutoplay() { startAutoplay(); }

      prevBtn.addEventListener('click', () => { prev(); resetAutoplay(); });
      nextBtn.addEventListener('click', () => { next(); resetAutoplay(); });

      // Drag / swipe
      let startX = 0, dragOffset = 0, isDragging = false, trackOffset = 0;

      viewport.addEventListener('mousedown', (e) => {
        isDragging = true; startX = e.clientX;
        trackOffset = currentIndex * slides[0].offsetWidth;
        track!.classList.add('is-dragging');
        stopAutoplay();
        e.preventDefault();
      });
      window.addEventListener('mousemove', (e) => {
        if (!isDragging) return;
        dragOffset = e.clientX - startX;
        track!.style.transform = `translateX(${-trackOffset + dragOffset}px)`;
      });
      window.addEventListener('mouseup', () => {
        if (!isDragging) return;
        isDragging = false;
        track!.classList.remove('is-dragging');
        if (dragOffset < -50) next();
        else if (dragOffset > 50) prev();
        else goTo(currentIndex);
        dragOffset = 0;
        resetAutoplay();
      });

      viewport.addEventListener('touchstart', (e) => {
        isDragging = true; startX = e.touches[0].clientX;
        trackOffset = currentIndex * slides[0].offsetWidth;
        track!.classList.add('is-dragging');
        stopAutoplay();
      }, { passive: true });
      viewport.addEventListener('touchmove', (e) => {
        if (!isDragging) return;
        dragOffset = e.touches[0].clientX - startX;
        track!.style.transform = `translateX(${-trackOffset + dragOffset}px)`;
      }, { passive: true });
      viewport.addEventListener('touchend', () => {
        if (!isDragging) return;
        isDragging = false;
        track!.classList.remove('is-dragging');
        if (dragOffset < -50) next();
        else if (dragOffset > 50) prev();
        else goTo(currentIndex);
        dragOffset = 0;
        resetAutoplay();
      }, { passive: true });

      // Pause on hover
      carousel.addEventListener('mouseenter', stopAutoplay);
      carousel.addEventListener('mouseleave', startAutoplay);

      // Resize
      window.addEventListener('resize', () => {
        perView = getPerView();
        buildDots();
        goTo(Math.min(currentIndex, maxIndex()));
      });

      buildDots();
      goTo(0);
      startAutoplay();
    });
  }

  initReviewsCarousel();
  document.addEventListener('astro:page-load', initReviewsCarousel);
</script>
