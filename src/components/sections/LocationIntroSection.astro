---
interface Props {
  badge: string;
  title: string;
  description: string;
  highlights: string[];
  serviceArea: string;
  guaranteeText: string;
  infoBoxText: string;
  buttonText: string;
  buttonHref: string;
  image: string;
  imageAlt?: string;
}

const {
  badge,
  title,
  description,
  highlights,
  serviceArea,
  guaranteeText,
  infoBoxText,
  buttonText,
  buttonHref,
  image,
  imageAlt = "HVAC Service"
} = Astro.props;
---

<section class="py-16 bg-white">
  <div class="container mx-auto px-4">
    <div class="grid md:grid-cols-2 gap-8 items-center">
      <!-- Left Column - Image -->
      <div class="relative">
        <img
          src={image}
          alt={imageAlt}
          class="w-full h-full object-cover rounded-lg shadow-lg"
        />
      </div>

      <!-- Right Column - Content -->
      <div class="space-y-6">
        <!-- Badge -->
        <div class="flex flex-wrap gap-3 items-center">
          <span class="text-[#dc2626] font-semibold text-sm flex items-center gap-2">
            <span class="w-2 h-2 bg-[#dc2626] rounded-full"></span>
            {badge}
          </span>
        </div>

        <!-- Title -->
        <h2 class="text-4xl md:text-5xl font-bold text-black italic leading-tight">
          {title}
        </h2>

        <!-- Description with highlights -->
        <p class="text-black text-base leading-relaxed">
          {description}
          {highlights.map((highlight, index) => (
            <Fragment>
              {index === 0 && ' '}
              <strong>{highlight}</strong>
              {index < highlights.length - 1 ? ', ' : '. '}
            </Fragment>
          ))}
          {serviceArea}
        </p>

        <!-- Decorative line -->
        <div class="flex items-center gap-3">
          <span class="w-3 h-3 bg-[#1e3a8a] rounded-full"></span>
          <div class="h-1 w-24 bg-[#F7B32B] rounded"></div>
        </div>

        <!-- Guarantee Text -->
        <p class="text-black text-base leading-relaxed">
          {guaranteeText}
        </p>

        <!-- Info Box -->
        <div class="border-2 border-[#1e3a8a] rounded-lg p-6 bg-blue-50">
          <p class="text-black text-base leading-relaxed">
            {infoBoxText}
          </p>
        </div>

        <!-- CTA Button -->
        <div>
          <a
            href={buttonHref}
            class="cta-btn inline-flex items-center gap-2 bg-brand-secondary text-gray-900 px-8 py-4 rounded-full font-semibold text-base transition-all shadow-lg"
          >
            {buttonText}
            <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" viewBox="0 0 20 20" fill="currentColor">
              <path d="M2 3a1 1 0 011-1h2.153a1 1 0 01.986.836l.74 4.435a1 1 0 01-.54 1.06l-1.548.773a11.037 11.037 0 006.105 6.105l.774-1.548a1 1 0 011.059-.54l4.435.74a1 1 0 01.836.986V17a1 1 0 01-1 1h-2C7.82 18 2 12.18 2 5V3z" />
            </svg>
          </a>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .cta-btn:hover {
    background-color: #A9E5BB !important;
    color: #1a1a1a !important;
  }
</style>
