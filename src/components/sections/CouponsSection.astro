---
import { getLocationText, siteConfig } from "@/config/site"

interface Coupon {
  icon?: string;
  label: string;
  discount: string;
  description: string;
  buttonText?: string;
  buttonHref?: string;
  backgroundImage?: string;
}

interface Props {
  title?: string;
  coupons: Coupon[];
  backgroundImage?: string;
  variant?: string;
}

const {
  title: rawTitle = "Specials and Offers",
  coupons,
} = Astro.props;

const title = getLocationText(rawTitle);

// HVAC coupon data matching the reference design
const hvacCoupons = [
  {
    category: "New Customers",
    title: "Coupon",
    subtitle: "Redeem & Save Today",
    discount: "20% OFF",
    description: "New Customer Discount. Cannot be combined with any other offer.",
    expiry: "* Offer Expires: December 2026",
    href: "/contact",
    variant: "light"
  },
  {
    category: "Free System Inspection",
    title: "Coupon", 
    subtitle: "Redeem & Save Today",
    discount: "FREE",
    description: "Complete HVAC System Inspection with any standard service call.",
    expiry: "* Offer Expires: December 2026",
    href: "/contact",
    variant: "featured"
  },
  {
    category: "Emergency Service",
    title: "Coupon",
    subtitle: "Redeem & Save Today", 
    discount: "$50 OFF",
    description: "Any Emergency Repair of $200 or More. Contact us now to get $50 Off today.",
    expiry: "* Offer Expires: December 2026",
    href: "/contact",
    variant: "light"
  }
];
---

<section class="coupons-section">
  <div class="container mx-auto px-4">
    <!-- Header -->
    <div class="text-center mb-12">
      <h2 class="text-3xl md:text-4xl font-bold text-white mb-4">
        Exclusive HVAC Offers
      </h2>
      <p class="text-lg text-white/80 max-w-2xl mx-auto">
        Professional Service. Exceptional Savings.
      </p>
    </div>

    <!-- Coupon Cards -->
    <div class="coupons-grid">
      {hvacCoupons.map((coupon, i) => (
        <div class={`coupon-card coupon-${coupon.variant}`}>
          <!-- Decorative Border -->
          <div class="coupon-border"></div>
          
          <!-- Header -->
          <div class="coupon-header">
            <h3 class="coupon-category">{coupon.category}</h3>
            <h4 class="coupon-title">{coupon.title}</h4>
            <p class="coupon-subtitle">{coupon.subtitle}</p>
          </div>
          
          <!-- Discount Badge -->
          <div class="coupon-badge">
            <span class="coupon-discount">{coupon.discount}</span>
          </div>
          
          <!-- Content -->
          <div class="coupon-content">
            <p class="coupon-description">{coupon.description}</p>
          </div>
          
          <!-- Footer -->
          <div class="coupon-footer">
            <p class="coupon-expiry">{coupon.expiry}</p>
          </div>
          
          <!-- Decorative Circles -->
          <div class="coupon-circles">
            <div class="circle circle-1"></div>
            <div class="circle circle-2"></div>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .coupons-section {
    background: 
      linear-gradient(135deg, rgba(52, 28, 28, 0.65) 0%, rgba(52, 28, 28, 0.70) 100%),
      url('https://ucarecdn.com/e390e204-5df9-4b50-97ad-8d0b54c2f9f5/complexairfiltersdiligentlypurifyindoorair.jpg') center/cover no-repeat;
    padding: 5rem 0;
    position: relative;
    overflow: hidden;
  }
  
  .coupons-section::before {
    content: "";
    position: absolute;
    inset: 0;
    background: 
      linear-gradient(180deg, rgba(0, 0, 0, 0.15) 0%, rgba(0, 0, 0, 0.25) 100%);
    z-index: 1;
  }

  .container {
    position: relative;
    z-index: 2;
  }

  /* Grid */
  .coupons-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(320px, 1fr));
    gap: 5rem;
    max-width: 1200px;
    margin: 0 auto;
  }

  /* Card Base */
  .coupon-card {
    background: #f8f9fa;
    border-radius: 12px;
    padding: 2rem;
    position: relative;
    overflow: hidden;
    transition: all 0.3s ease;
    box-shadow: 0 8px 32px rgba(0, 0, 0, 0.1);
    min-height: 400px;
    display: flex;
    flex-direction: column;
  }

  .coupon-card:hover {
    transform: translateY(-8px);
    box-shadow: 0 16px 48px rgba(0, 0, 0, 0.15);
  }

  /* Featured Card */
  .coupon-featured {
    background: linear-gradient(135deg, #A9E5BB 0%, #8dd3c7 100%);
    color: white;
    transform: scale(1.15);
  }

  .coupon-featured:hover {
    transform: scale(1.15) translateY(-8px);
  }

  .coupon-featured .coupon-category,
  .coupon-featured .coupon-title,
  .coupon-featured .coupon-subtitle,
  .coupon-featured .coupon-description,
  .coupon-featured .coupon-expiry {
    color: #1e293b;
  }

  .coupon-featured .coupon-badge {
    background: #1e293b;
  }

  .coupon-featured .coupon-discount {
    color: white;
  }

  /* Decorative Border */
  .coupon-border {
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    border: 3px dashed #cbd5e1;
    border-radius: 12px;
    pointer-events: none;
  }

  .coupon-featured .coupon-border {
    border-color: rgba(255, 255, 255, 0.6);
  }

  /* Header */
  .coupon-header {
    text-align: center;
    margin-bottom: 1.5rem;
  }

  .coupon-category {
    font-size: 1rem;
    font-weight: 600;
    color: #1e293b;
    margin-bottom: 0.5rem;
  }

  .coupon-title {
    font-size: 2rem;
    font-weight: 700;
    color: #E3170A;
    margin-bottom: 0.25rem;
    line-height: 1;
  }

  .coupon-subtitle {
    font-size: 0.875rem;
    color: #64748b;
    margin: 0;
  }

  /* Badge */
  .coupon-badge {
    background: #1e293b;
    color: white;
    padding: 0.75rem 1.5rem;
    border-radius: 8px;
    text-align: center;
    margin: 1.5rem auto;
    width: fit-content;
  }

  .coupon-discount {
    font-size: 1.5rem;
    font-weight: 900;
    letter-spacing: 0.05em;
  }

  /* Content */
  .coupon-content {
    flex: 1;
    text-align: center;
    margin-bottom: 1.5rem;
  }

  .coupon-description {
    font-size: 0.95rem;
    color: #475569;
    line-height: 1.6;
    margin: 0;
  }

  /* Footer */
  .coupon-footer {
    text-align: center;
    margin-top: auto;
  }

  .coupon-expiry {
    font-size: 0.8rem;
    color: #64748b;
    font-style: italic;
    margin: 0;
  }

  /* Decorative Circles */
  .coupon-circles {
    position: absolute;
    inset: 0;
    pointer-events: none;
    overflow: hidden;
    border-radius: 12px;
  }

  .circle {
    position: absolute;
    width: 80px;
    height: 80px;
    border-radius: 50%;
    background: rgba(45, 30, 47, 0.25);
  }

  .circle-1 {
    top: -40px;
    right: -40px;
  }

  .circle-2 {
    bottom: -40px;
    left: -40px;
  }

  .coupon-featured .circle {
    background: rgba(255, 255, 255, 0.2);
  }

  /* Responsive */
  @media (max-width: 768px) {
    .coupons-section {
      padding: 3rem 0;
    }
    
    .coupons-grid {
      grid-template-columns: 1fr;
      gap: 1.5rem;
    }
    
    .coupon-featured {
      transform: none;
    }
    
    .coupon-featured:hover {
      transform: translateY(-8px);
    }
  }
</style>