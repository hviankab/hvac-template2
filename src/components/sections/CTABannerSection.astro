---
import { siteConfig } from "@/config/site"

interface Props {
  badge?: string;
  title: string;
  description?: string;
  buttonText?: string;
  buttonHref?: string;
  backgroundImage?: string;
}

const {
  badge = "GET STARTED",
  title,
  description,
  buttonText = "Get Started Today",
  buttonHref = "/contact",
  backgroundImage = "/images/hvac-hero.jpg"
} = Astro.props;
---

<section class="cta-banner-section">
  <div class="cta-banner-overlay"></div>
  <div class="cta-banner-bg" style={`background-image: url('${backgroundImage}');`}></div>
  
  <div class="container mx-auto px-4">
    <div class="cta-banner-content" data-animate="fade-up">
      {badge && (
        <span class="cta-badge">{badge}</span>
      )}
      <h2 class="cta-title">{title}</h2>
      {description && (
        <p class="cta-description">{description}</p>
      )}
      <a href={buttonHref} class="cta-button">
        {buttonText}
      </a>
    </div>
  </div>
</section>

<style>
  .cta-banner-section {
    position: relative;
    padding: 5rem 0;
    overflow: hidden;
    border-bottom: 4px solid #F7B32B;
  }

  .cta-banner-bg {
    position: absolute;
    inset: 0;
    background-size: cover;
    background-position: center;
    background-repeat: no-repeat;
    z-index: 1;
  }

  .cta-banner-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(135deg, rgba(0, 0, 0, 0.85) 0%, rgba(0, 0, 0, 0.65) 100%);
    z-index: 2;
  }

  .container {
    position: relative;
    z-index: 3;
  }

  .cta-banner-content {
    text-align: center;
    max-width: 800px;
    margin: 0 auto;
  }

  .cta-badge {
    display: inline-block;
    font-size: 0.75rem;
    font-weight: 700;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: #F7B32B;
    margin-bottom: 1.5rem;
  }

  .cta-title {
    font-size: 2.5rem;
    font-weight: 700;
    color: white;
    line-height: 1.2;
    margin-bottom: 1.5rem;
  }

  .cta-description {
    font-size: 1.125rem;
    line-height: 1.7;
    color: rgba(255, 255, 255, 0.9);
    margin-bottom: 2.5rem;
    max-width: 600px;
    margin-left: auto;
    margin-right: auto;
  }

  .cta-button {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 1rem 2.5rem;
    background: #F7B32B;
    color: #000000;
    font-size: 1rem;
    font-weight: 700;
    border-radius: 9999px;
    text-decoration: none;
    transition: all 0.3s ease;
    box-shadow: 0 4px 16px rgba(247, 179, 43, 0.3);
  }

  .cta-button:hover {
    background: #1e3a8a;
    color: white;
    transform: translateY(-2px);
    box-shadow: 0 6px 24px rgba(30, 58, 138, 0.4);
  }

  @media (max-width: 768px) {
    .cta-banner-section {
      padding: 3.5rem 0;
    }

    .cta-title {
      font-size: 1.875rem;
    }

    .cta-description {
      font-size: 1rem;
    }
  }
</style>
