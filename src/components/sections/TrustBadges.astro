---
interface Badge {
  name: string;
  image: string;
  alt?: string;
}

interface Props {
  badges?: Badge[];
  heading?: string;
}

const { 
  badges = [
    { name: "Home Advisor", image: "https://johnh967.sg-host.com/wp-content/uploads/2024/11/Home-Advisor-Logo.webp" },
    { name: "BBB", image: "https://johnh967.sg-host.com/wp-content/uploads/2024/11/BBB-Logo.webp" },
    { name: "Google Reviews", image: "https://johnh967.sg-host.com/wp-content/uploads/2024/11/Google-Reviews-Logo.webp" },
    { name: "Angie's List Award", image: "https://johnh967.sg-host.com/wp-content/uploads/2024/11/Angies-List-Award.webp" },
    { name: "Licensed", image: "https://johnh967.sg-host.com/wp-content/uploads/2024/11/Licensed.webp" }
  ],
  heading = "Achievement Starts with Action."
} = Astro.props;

// Duplicate badges for seamless loop
const duplicatedBadges = [...badges, ...badges, ...badges];
---

<section class="trust-badges-section py-6 bg-white">
  <div class="container mx-auto px-4">
    <div class="flex flex-col md:flex-row items-center justify-between gap-6">
      <!-- Left side: Heading -->
      <div class="flex items-center gap-2 flex-shrink-0" data-animate="fade-right">
        <span class="text-brand-secondary text-xl">★</span>
        <h2 class="text-lg md:text-xl font-bold text-gray-800">{heading}</h2>
      </div>
      
      <!-- Right side: Carousel -->
      <div class="carousel-container flex-1 max-w-3xl" data-animate="fade-left">
        <div class="carousel-track">
          {duplicatedBadges.map((badge, index) => (
            <div class="carousel-item">
              <img 
                src={badge.image} 
                alt={badge.alt || badge.name}
                class="h-12 md:h-14 w-auto object-contain opacity-70"
                width="187"
                height="84"
                loading="lazy"
                decoding="async"
              />
            </div>
          ))}
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .trust-badges-section {
    position: relative;
    border-top: none;
    border-bottom: none;
    box-shadow: 0 -6px 20px -4px rgba(0, 0, 0, 0.12), 0 6px 20px -4px rgba(0, 0, 0, 0.12);
  }

  .carousel-container {
    overflow: hidden;
    position: relative;
  }

  .carousel-track {
    display: flex;
    align-items: center;
    gap: 3rem;
    width: max-content;
    animation: scroll 15s linear infinite;
    will-change: transform;
  }

  .carousel-item {
    flex-shrink: 0;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  @keyframes scroll {
    0% {
      transform: translate3d(0, 0, 0);
    }
    100% {
      transform: translate3d(calc(-100% / 3), 0, 0);
    }
  }

  @media (min-width: 768px) {
    .carousel-track {
      gap: 4rem;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .carousel-track {
      animation: none;
    }
  }
</style>
