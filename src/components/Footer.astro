---
import { siteConfig } from "@/config/site"

const currentYear = new Date().getFullYear()

const quickLinks = [
  { title: "Home", href: "/" },
  { title: "About Us", href: "/about" },
  { title: "Services", href: "/air-conditioning" },
  { title: "Reviews", href: "/reviews" },
  { title: "Careers", href: "/careers" },
  { title: "Contact", href: "/contact" },
]

const services = [
  { title: "AC Repair", href: "/air-conditioning/ac-repair" },
  { title: "AC Installation", href: "/air-conditioning/ac-installation-replacement" },
  { title: "24/7 AC Repairs", href: "/emergency/24-7-ac-repairs" },
  { title: "24/7 Emergency Repairs", href: "/emergency/24-7-emergency-repairs" },
  { title: "Commercial HVAC Repair", href: "/commercial/hvac-repair" },
  { title: "Commercial HVAC Installation", href: "/commercial/hvac-installation" },
  { title: "Maintenance Plan", href: "/maintenance-plan" },
  { title: "Financing", href: "/financing" },
]
---

<footer style="background-color: #341C1C;" class="text-white">
<style>
  footer, footer * {
    color: #ffffff !important;
    font-size: 1rem !important;
  }
  footer h3, footer h4 {
    font-size: 1.125rem !important;
    font-weight: 700 !important;
  }
  footer h3.text-xl, footer h3.text-2xl {
    font-size: 1.5rem !important;
  }
  footer button[type="submit"] {
    color: #000000 !important;
  }
</style>

  <!-- Newsletter bar -->
  <div class="border-b border-white/10">
    <div class="container mx-auto px-4 py-8 flex flex-col md:flex-row items-center justify-between gap-6">
      <div class="flex-shrink-0">
        <h3 class="text-xl md:text-2xl font-bold leading-snug">
          Receive Smart Styling Ideas<br />Straight To Your Inbox.
        </h3>
      </div>
      <form class="flex items-center gap-2 w-full md:w-auto" action="#" method="POST">
        <div class="flex items-center bg-white rounded-full overflow-hidden pr-1 pl-4 gap-2">
          <input
            type="email"
            name="email"
            placeholder="Email Address"
            class="py-2.5 text-sm text-gray-800 bg-transparent focus:outline-none w-52"
          />
          <button type="submit" class="bg-brand-secondary text-black px-5 py-2 rounded-full text-sm font-semibold whitespace-nowrap hover:bg-[#A9E5BB] hover:text-black transition-all">
            Notify Me
          </button>
        </div>
      </form>
    </div>
  </div>

  <!-- Main footer grid -->
  <div class="container mx-auto px-4 py-12">
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-10">

      <!-- Col 1: Logo + description + social -->
      <div>
        <a href="/" class="inline-block mb-4">
          <img src={siteConfig.logo.src} alt={siteConfig.logo.alt} class="h-24 object-contain" />
        </a>
        <p class="text-sm text-white/60 leading-relaxed mb-6">
          Professional heating and cooling solutions for your home and business. Available 24/7.
        </p>
        <div class="flex items-center gap-4">
          {siteConfig.social.facebook && <a href={siteConfig.social.facebook} aria-label="Facebook" class="text-white/60 hover:text-brand-secondary transition-colors">
            <svg xmlns="http://www.w3.org/2000/svg" class="w-7 h-7" viewBox="0 0 24 24" fill="currentColor"><path d="M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z"/></svg>
          </a>}
          {siteConfig.social.twitter && <a href={siteConfig.social.twitter} aria-label="X (Twitter)" class="text-white/60 hover:text-brand-secondary transition-colors">
            <svg xmlns="http://www.w3.org/2000/svg" class="w-7 h-7" viewBox="0 0 24 24" fill="currentColor"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-4.714-6.231-5.401 6.231H2.744l7.737-8.835L2.25 2.25h6.988l4.26 5.632 4.746-5.632zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>
          </a>}
          {siteConfig.social.instagram && <a href={siteConfig.social.instagram} aria-label="Instagram" class="text-white/60 hover:text-brand-secondary transition-colors">
            <svg xmlns="http://www.w3.org/2000/svg" class="w-7 h-7" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect width="20" height="20" x="2" y="2" rx="5"/><path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"/><line x1="17.5" x2="17.51" y1="6.5" y2="6.5"/></svg>
          </a>}
          {siteConfig.social.linkedin && <a href={siteConfig.social.linkedin} aria-label="LinkedIn" class="text-white/60 hover:text-brand-secondary transition-colors">
            <svg xmlns="http://www.w3.org/2000/svg" class="w-7 h-7" viewBox="0 0 24 24" fill="currentColor"><path d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-2-2 2 2 0 0 0-2 2v7h-4v-7a6 6 0 0 1 6-6z"/><rect width="4" height="12" x="2" y="9"/><circle cx="4" cy="4" r="2"/></svg>
          </a>}
        </div>
      </div>

      <!-- Col 2: Quick Links -->
      <div>
        <h4 class="text-base font-bold mb-4 pb-2 border-b border-brand-secondary/50">Quick Link</h4>
        <ul class="grid grid-cols-2 gap-x-4 gap-y-2">
          {quickLinks.map((link) => (
            <li><a href={link.href} class="text-sm text-white/60 hover:text-brand-secondary transition-colors">{link.title}</a></li>
          ))}
        </ul>
      </div>

      <!-- Col 3: Our Services -->
      <div>
        <h4 class="text-base font-bold mb-4 pb-2 border-b border-brand-secondary/50">Our Services</h4>
        <ul class="space-y-2">
          {services.map((s) => (
            <li><a href={s.href} class="text-sm text-white/60 hover:text-brand-secondary transition-colors">{s.title}</a></li>
          ))}
        </ul>
      </div>

      <!-- Col 4: Contact Info -->
      <div>
        <h4 class="text-base font-bold mb-4 pb-2 border-b border-brand-secondary/50">Contact Info</h4>
        <ul class="space-y-3">
          <li class="flex items-start gap-3 text-sm text-white/60">
            <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 mt-0.5 text-brand-secondary flex-shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M22 16.92v3a2 2 0 01-2.18 2 19.79 19.79 0 01-8.63-3.07 19.5 19.5 0 01-6-6 19.79 19.79 0 01-3.07-8.67A2 2 0 014.11 2h3a2 2 0 012 1.72c.127.96.361 1.903.7 2.81a2 2 0 01-.45 2.11L8.09 9.91a16 16 0 006 6l1.27-1.27a2 2 0 012.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0122 16.92z"/></svg>
            <a href={`tel:${siteConfig.contact.phone}`} class="hover:text-brand-secondary transition-colors">{siteConfig.contact.phoneFormatted}</a>
          </li>
          <li class="flex items-start gap-3 text-sm text-white/60">
            <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 mt-0.5 text-brand-secondary flex-shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect width="20" height="16" x="2" y="4" rx="2"/><path d="m22 7-8.97 5.7a1.94 1.94 0 01-2.06 0L2 7"/></svg>
            <a href={`mailto:${siteConfig.contact.email}`} class="hover:text-brand-secondary transition-colors">{siteConfig.contact.email}</a>
          </li>
          <li class="flex items-start gap-3 text-sm text-white/60">
            <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 mt-0.5 text-brand-secondary flex-shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M20 10c0 6-8 12-8 12s-8-6-8-12a8 8 0 0116 0z"/><circle cx="12" cy="10" r="3"/></svg>
            {siteConfig.location.fullAddress}
          </li>
        </ul>
      </div>

    </div>
  </div>

  <!-- Bottom bar -->
  <div class="border-t border-white/10">
    <div class="container mx-auto px-4 py-4 text-center text-xs text-white/40">
      <span>© {currentYear} {siteConfig.business.name}. All rights reserved.</span>
    </div>
  </div>

</footer>
