---
import { siteConfig } from "@/config/site"

interface Props {
  delay?: number;
  showOnce?: boolean;
  triggerId?: string;
}

const {
  delay = 5000,
  showOnce = true,
  triggerId = "free-scan-trigger",
} = Astro.props;
---

<div
  id="popup-modal"
  class="fixed inset-0 z-[200] hidden items-center justify-center bg-black/60 backdrop-blur-sm overflow-y-auto"
  role="dialog"
  aria-modal="true"
  aria-labelledby="popup-title"
  data-delay={delay}
  data-show-once={showOnce}
  data-trigger-id={triggerId}
>
  <div class="popup-wrapper animate-scale-in">
    <!-- Offer sticker overlay (outside container to avoid overflow clip) -->
    <img
      src="/images/offer.png"
      alt="Special offer"
      class="popup-sticker"
      width="160"
      height="160"
      loading="lazy"
      decoding="async"
    />

  <div class="popup-container">

    <!-- Close button -->
    <button
      id="close-popup"
      class="popup-close"
      aria-label="Close popup"
    >
      <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M6 18L18 6M6 6l12 12" />
      </svg>
    </button>

    <!-- Top: Full-width gradient banner -->
    <div class="popup-banner">
      <div class="popup-banner-bg"></div>
      <img
        src="https://ucarecdn.com/315825d3-5856-474f-8ac1-f793441976f7/-/preview/480x320/"
        alt="Professional HVAC team"
        class="popup-banner-img"
        width="480"
        height="320"
        loading="lazy"
        decoding="async"
      />
      <div class="popup-banner-content">
        <span class="popup-eyebrow">Limited Time Offer</span>
        <div class="popup-discount">
          <span class="popup-dollar">$</span>50
          <span class="popup-off">OFF</span>
        </div>
        <p class="popup-qualifier">Any service over $500</p>
      </div>
      <!-- Decorative circles -->
      <div class="popup-circle popup-circle-1"></div>
      <div class="popup-circle popup-circle-2"></div>
    </div>

    <!-- Bottom: Content area -->
    <div class="popup-body">
      <h2 id="popup-title" class="popup-heading">
        Your Comfort<br/>Can't Wait
      </h2>
      <p class="popup-subtext">
        Expert HVAC service, 24/7 emergency response, and financing options available.
      </p>

      <!-- Trust indicators as inline pills -->
      <div class="popup-pills">
        <span class="popup-pill">✓ Licensed & Insured</span>
        <span class="popup-pill">✓ 24/7 Available</span>
        <span class="popup-pill">✓ 5-Star Rated</span>
      </div>

      <!-- CTA stack -->
      <div class="popup-actions">
        <a href="/contact" class="popup-btn-primary">
          Claim Your Discount
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M13 7l5 5m0 0l-5 5m5-5H6" />
          </svg>
        </a>
        <a href={`tel:${siteConfig.contact.phone}`} class="popup-btn-phone">
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
          </svg>
          {siteConfig.contact.phoneFormatted}
        </a>
      </div>

      <button id="close-popup-bottom" class="popup-dismiss">No thanks, maybe later</button>
    </div>
  </div>
  </div>
</div>

<script>
  function showPopup(force = false) {
    const popup = document.getElementById("popup-modal");
    if (!popup) return;
    if (!force && sessionStorage.getItem("popup-shown") === "true") return;
    popup.classList.remove("hidden");
    popup.classList.add("flex");
    document.body.style.overflow = "hidden";
    sessionStorage.setItem("popup-shown", "true");
  }

  function closePopup() {
    const popup = document.getElementById("popup-modal");
    if (!popup) return;
    popup.classList.add("hidden");
    popup.classList.remove("flex");
    document.body.style.overflow = "";
  }

  function initPopup() {
    const popup = document.getElementById("popup-modal");
    if (!popup) return;

    const alreadyShown = sessionStorage.getItem("popup-shown") === "true";
    const triggerId = popup.getAttribute("data-trigger-id");

    document.getElementById("close-popup")?.addEventListener("click", closePopup);
    document.getElementById("close-popup-bottom")?.addEventListener("click", closePopup);
    popup.addEventListener("click", (e) => { if (e.target === popup) closePopup(); });
    document.addEventListener("keydown", (e) => {
      if (e.key === "Escape" && !popup.classList.contains("hidden")) closePopup();
    });

    if (triggerId) {
      document.getElementById(triggerId)?.addEventListener("click", (e) => {
        e.preventDefault();
        showPopup();
      });
    }

    const delay = parseInt(popup.getAttribute("data-delay") || "0") || 0;
    if (delay > 0 && window.innerWidth >= 768 && !alreadyShown) {
      setTimeout(() => { if (window.innerWidth >= 768) showPopup(); }, delay);
    }
  }

  document.addEventListener("astro:page-load", initPopup);
</script>

<style>
  @keyframes scale-in {
    from { opacity: 0; transform: scale(0.92) translateY(20px); }
    to { opacity: 1; transform: scale(1) translateY(0); }
  }
  .animate-scale-in {
    animation: scale-in 0.35s cubic-bezier(0.16, 1, 0.3, 1);
  }

  .popup-wrapper {
    position: relative;
    width: 100%;
    max-width: 400px;
    margin: 1rem;
  }

  .popup-sticker {
    position: absolute;
    top: 7rem;
    left: -3rem;
    width: 180px;
    height: 180px;
    z-index: 40;
    object-fit: contain;
    filter: drop-shadow(0 6px 20px rgba(0, 0, 0, 0.4));
    transform: rotate(-10deg);
    pointer-events: none;
  }

  .popup-container {
    position: relative;
    width: 100%;
    border-radius: 1.5rem;
    overflow: hidden;
    box-shadow: 0 25px 80px rgba(0, 0, 0, 0.3);
  }

  .popup-close {
    position: absolute;
    top: 1rem;
    right: 1rem;
    z-index: 30;
    width: 2.5rem;
    height: 2.5rem;
    display: flex;
    align-items: center;
    justify-content: center;
    border-radius: 50%;
    background: rgba(255, 255, 255, 0.15);
    backdrop-filter: blur(8px);
    color: #fff;
    border: 1px solid rgba(255, 255, 255, 0.2);
    cursor: pointer;
    transition: background 0.2s, transform 0.2s;
  }
  .popup-close:hover {
    background: rgba(255, 255, 255, 0.3);
    transform: scale(1.1);
  }

  /* === Banner === */
  .popup-banner {
    position: relative;
    padding: 2rem 2rem 1.75rem;
    overflow: hidden;
    text-align: center;
  }
  .popup-banner-img {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    z-index: 0;
  }
  .popup-banner-bg {
    position: absolute;
    inset: 0;
    background: linear-gradient(135deg, color-mix(in srgb, var(--brand-secondary) 85%, transparent) 0%, color-mix(in srgb, var(--brand-secondary) 50%, black) 60%, color-mix(in srgb, var(--brand-secondary) 30%, black) 100%);
    z-index: 1;
  }
  .popup-banner-content {
    position: relative;
    z-index: 2;
  }

  .popup-eyebrow {
    display: inline-block;
    background: color-mix(in srgb, var(--brand-highlight) 20%, transparent);
    border: 1px solid color-mix(in srgb, var(--brand-highlight) 50%, transparent);
    color: var(--brand-highlight);
    padding: 0.35rem 1.25rem;
    border-radius: 9999px;
    font-size: 0.75rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.15em;
    margin-bottom: 1.25rem;
  }

  .popup-discount {
    font-family: 'Poppins', system-ui, sans-serif;
    font-weight: 700;
    font-size: 5rem;
    line-height: 0.9;
    color: #fff;
    letter-spacing: -0.03em;
    text-shadow: 0 4px 20px rgba(0, 0, 0, 0.3);
  }
  .popup-dollar {
    font-size: 3rem;
    vertical-align: super;
    margin-right: -0.1em;
    color: var(--brand-highlight);
  }
  .popup-off {
    display: block;
    font-size: 2.25rem;
    letter-spacing: 0.15em;
    opacity: 0.85;
    margin-top: -0.2rem;
  }

  .popup-qualifier {
    color: rgba(255, 255, 255, 0.7);
    font-size: 0.875rem;
    margin-top: 0.5rem;
  }

  /* Decorative circles */
  .popup-circle {
    position: absolute;
    border-radius: 50%;
    border: 1px solid rgba(255, 255, 255, 0.08);
    z-index: 1;
  }
  .popup-circle-1 {
    width: 200px;
    height: 200px;
    top: -60px;
    right: -40px;
    background: rgba(255, 255, 255, 0.04);
  }
  .popup-circle-2 {
    width: 140px;
    height: 140px;
    bottom: -30px;
    left: -30px;
    background: rgba(255, 255, 255, 0.03);
  }

  /* === Body === */
  .popup-body {
    background: var(--card);
    padding: 1.5rem 2rem 1.5rem;
    text-align: center;
    border-top: 3px solid var(--brand-highlight);
  }

  .popup-heading {
    font-family: 'Poppins', system-ui, sans-serif;
    font-weight: 700;
    font-size: 1.5rem;
    line-height: 1.15;
    color: var(--foreground);
    margin-bottom: 0.35rem;
  }

  .popup-subtext {
    font-size: 0.9rem;
    color: var(--muted-foreground);
    line-height: 1.5;
    margin-bottom: 1rem;
  }

  /* Trust pills */
  .popup-pills {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 0.4rem;
    margin-bottom: 1.25rem;
  }
  .popup-pill {
    display: inline-flex;
    align-items: center;
    gap: 0.25rem;
    background: var(--brand-tertiary);
    color: var(--brand-secondary);
    padding: 0.3rem 0.75rem;
    border-radius: 9999px;
    font-size: 0.7rem;
    font-weight: 600;
  }

  /* CTA buttons */
  .popup-actions {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
    margin-bottom: 1rem;
  }

  .popup-btn-primary {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 0.5rem;
    width: 100%;
    padding: 0.8rem 1.75rem;
    background: linear-gradient(160deg, var(--brand-secondary) 0%, color-mix(in srgb, var(--brand-secondary) 60%, black) 100%);
    color: #fff;
    font-family: 'Poppins', system-ui, sans-serif;
    font-weight: 700;
    font-size: 1rem;
    border-radius: 9999px;
    text-decoration: none;
    letter-spacing: 0.02em;
    box-shadow: 0 6px 24px color-mix(in srgb, var(--brand-secondary) 35%, transparent), inset 0 1px 0 color-mix(in srgb, var(--brand-highlight) 30%, transparent);
    transition: transform 0.25s, box-shadow 0.25s;
  }
  .popup-btn-primary:hover {
    transform: translateY(-2px) scale(1.02);
    box-shadow: 0 10px 36px color-mix(in srgb, var(--brand-secondary) 45%, transparent);
  }

  .popup-btn-phone {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 0.5rem;
    width: 100%;
    padding: 0.7rem 1.75rem;
    background: var(--foreground);
    color: var(--background);
    font-weight: 700;
    font-size: 1rem;
    border-radius: 9999px;
    text-decoration: none;
    letter-spacing: 0.03em;
    transition: opacity 0.25s, transform 0.25s;
  }
  .popup-btn-phone:hover {
    opacity: 0.88;
    transform: translateY(-2px);
  }

  .popup-dismiss {
    background: none;
    border: none;
    color: var(--muted-foreground);
    font-size: 0.8rem;
    cursor: pointer;
    padding: 0.25rem;
    transition: color 0.2s;
  }
  .popup-dismiss:hover {
    color: var(--foreground);
  }

  @media (max-width: 480px) {
    .popup-sticker {
      width: 110px;
      height: 110px;
      top: -1.5rem;
      left: -1.5rem;
    }
    .popup-container {
      border-radius: 1.25rem;
    }
    .popup-banner {
      padding: 1.75rem 1.25rem 1.5rem;
    }
    .popup-discount {
      font-size: 4rem;
    }
    .popup-dollar {
      font-size: 2.5rem;
    }
    .popup-off {
      font-size: 1.75rem;
    }
    .popup-body {
      padding: 1.25rem 1.25rem 1.25rem;
    }
    .popup-heading {
      font-size: 1.3rem;
    }
  }
</style>
